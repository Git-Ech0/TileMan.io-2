    // ── Client-side loop-closure prediction ──────────────────────────────
    // trs is server-authoritative and only ever changes wholesale, in one
    // of three socket handlers (`player.trs = trailPayload.slice()` /
    // `payload[1].slice()` / `p.trs = payload.t`) — never appended to
    // locally. So a run closing (player returns to territory) is only
    // reflected in trs once that next payload arrives, a full round-trip
    // after the fact. That's the residual gap the per-cell territory
    // filtering above can't close on its own: a BRAND NEW capture's tiles
    // don't exist in gridMatrix as "owned" yet either, since painting them
    // is also server-driven (the 'fa' fill event) — so between "you
    // physically closed the loop" and "the server told you so twice over"
    // there's a window where neither check sees it.
    //
    // But the closure itself doesn't need the server to be known: the
    // ONLY way to end a run is to step onto a tile that was ALREADY this
    // player's territory before the run began — you can never close a
    // loop onto brand-new ground — so gridMatrix already has the right
    // answer for that specific tile, with zero latency, the instant the
    // player (locally predicted/interpolated position, same as every
    // other check in this file) is standing on it. The moment that's
    // true, whatever's currently sitting in trs describes a finished
    // trip, not a live hazard — full stop, regardless of what any
    // individual cell in it looks like — and it keeps describing that
    // same finished trip, even if the player immediately sets off again,
    // right up until a genuinely new trs array actually arrives to
    // replace it. Reference identity is what detects that replacement:
    // every one of the three handlers above hands trs a brand-new array,
    // so `!==` is all that's needed to notice a fresh payload landed and
    // go back to trusting it at face value.
    const lastKnownTrs = new Map(); // player.id -> trs array reference last reconciled
    const trailClosurePredicted = new Map(); // player.id -> boolean

    function isTrailStale(player) {
      const id = player.id;

      // If we've seen a fresh trs payload, reset the stale prediction.
      if (lastKnownTrs.get(id) !== player.trs) {
        lastKnownTrs.set(id, player.trs);
        trailClosurePredicted.set(id, false);
      }

      // Only predict closure when the trail array is actually empty/gone —
      // meaning the server has confirmed the loop closed and territory was
      // awarded. If trs still has segments, the trail is live regardless of
      // whether the player's head is currently standing on owned tiles.
      // The old logic set stale=true the moment the head touched owned land,
      // which fires mid-trail whenever a player routes through their own
      // territory (common), wiping the whole trail from the hazard set and
      // breaking FF until the next trs payload arrived.
      const trs = player.trs;
      const trailIsEmpty = !trs || trs.length < 2;
      if (trailIsEmpty && isOwnedTerritoryTile(player, Math.floor(player.pos[0]), Math.floor(player.pos[1]))) {
        trailClosurePredicted.set(id, true);
      }

      return trailClosurePredicted.get(id) === true;
