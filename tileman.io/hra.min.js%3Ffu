      }

      // Safety 2: Protect any alive player on your screen
      if (!force && players && players.length > 0) {
        for (let i = 0; i < players.length; i++) {
          if (players[i] && players[i].c) {
            const playerColor = String(players[i].c).toLowerCase();
            if (cleanColor === playerColor && players[i].de === null) {
              return; // Target player is still alive, cancel sweep
