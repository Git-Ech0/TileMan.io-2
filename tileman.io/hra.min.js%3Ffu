      let spanStartX;
      const isZeroSize = snakeSizeRatio === 0;
      const pixelAdj = isZeroSize ? 0.5 : 0;
      let drawnRows = 0;
      for (let gy = minY; gy <= maxY; gy++) {
        cachedColor = null;
        drawnRows++;
        for (let gx = minX; gx <= maxX; gx++) {
          const cell = gridMatrix[gx][gy];
          let stroke = snakeSizeRatio;
          let fill = cell.c;
