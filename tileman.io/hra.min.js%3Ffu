      p2pChatSend.type = 'button';
      p2pChatSend.textContent = 'Send';
      p2pChatSend.disabled = true;
      p2pChatInputRow.appendChild(p2pChatSend);

      p2pChat.appendChild(p2pChatInputRow);
      p2pBody.appendChild(p2pChat);

      p2pPanel.appendChild(p2pBody);

      document.body.appendChild(p2pPanel);

      if (typeof initP2PPanelResize === 'function') {
        initP2PPanelResize(p2pPanel);
      }
      if (typeof initP2PPanelDrag === 'function') {
        initP2PPanelDrag(p2pPanel, p2pTabs);
      }
      if (typeof positionP2PPanel === 'function') {
        positionP2PPanel();
      }

      const specOverlay = document.createElement('div');
      specOverlay.id = 'spectator-overlay';
      specOverlay.style.display = 'none';

      const closeBtn = document.createElement('button');
      closeBtn.id = 'spectator-close-btn';
      closeBtn.type = 'button';
      closeBtn.textContent = 'EXIT SPECTATING';
      specOverlay.appendChild(closeBtn);

      const renderView = document.createElement('img');
      renderView.id = 'spectator-render-view';
      renderView.alt = 'Awaiting frames from broadcaster...';
      specOverlay.appendChild(renderView);

      const deathNotice = document.createElement('div');
      deathNotice.id = 'spectator-death-notice';
      deathNotice.style.display = 'none';
      specOverlay.appendChild(deathNotice);

      document.body.appendChild(specOverlay);
    }

    function applyP2PVisibility() {
      const isTabEnabled = getLocalStorage('p_tab') !== 'false';
      const isInfoEnabled = getLocalStorage('s_info') !== 'false';

      const panel = document.getElementById('p2p-panel');
      if (panel) {
        panel.style.display = isTabEnabled ? 'flex' : 'none';
      }
      const info = document.getElementById('spectator-info');
      if (info) {
        info.style.display = isInfoEnabled ? 'block' : 'none';
      }
    }

    function fadeSpectatingUI() {
      isScoreboardActive &&
        !isSpectating &&
        (gameOverHUD.classList.add('hidena'),
        clearTimeout(hudOpacityTimeoutId),
        (hudOpacityTimeoutId = setTimeout(function () {
          gameOverHUD.classList.remove('hidena');
        }, 1500)));
    }

    // eslint-disable-next-line no-unused-vars
    function getDeathsCount() {
      return parseFloat(getLocalStorage('rekhry')) || 0;
    }

    function addDeathsCount(increment) {
      if (increment) {
        let count = getDeathsCount();
        count += increment;
        setLocalStorage('rekhry', count);
      }
    }

    function getPlaytime() {
      return parseInt(getLocalStorage('rekcashier')) || 0;
    }

    function updateTimeAlive(savePartialTime) {
      if (sessionStartTime !== null) {
        let total = getPlaytime() - playtimeCheckpoint;
        const sessionSeconds = Math.floor((performance.now() - sessionStartTime) / 1000);
        total += sessionSeconds;
        setLocalStorage('rekcashier', total);
        if (savePartialTime) {
          playtimeCheckpoint = sessionSeconds;
        } else {
          sessionStartTime = null;
          playtimeCheckpoint = 0;
        }
      }
    }

    function getScoreHistory() {
      try {
        const data = JSON.parse(getLocalStorage('rekx'));
        return Array.isArray(data) ? data : [];
      } catch (e) {
        return [];
      }
    }

    function recordScoreEntry(isGameOver) {
      if (gameRunStartTime !== null) {
        const duration = Math.ceil((performance.now() - gameRunStartTime) / 1000);
        let history = getScoreHistory();
        if (isRecording) {
          history.pop();
        }
        history.push([Date.now(), duration, isGameOver]);
        history = history.slice(-5);
        setLocalStorage('rekx', JSON.stringify(history));
        if (!isGameOver) {
          gameRunStartTime = null;
          isRecording = false;
          clearInterval(sessionIntervalId);
        } else {
          isRecording = true;
        }
      }
    }

    function generateFingerprint() {
      Fingerprint2.get({}, function (components) {
        const values = components.map(function (c) {
          return c.value;
        });
        fingerprintHash = Fingerprint2.x64hash128(values.join(''), 31);
      });
    }

    function generateUUID() {
      const p1 = (Array(10).join('0') + Date.now().toString(36)).slice(-9),
        p2 = (Math.random().toString(36).substring(2) + Array(9).join('0')).slice(0, 8),
        p3 = (Math.random().toString(36).substring(2) + Array(9).join('0')).slice(0, 8);
      return p1 + p2 + p3;
    }

    // eslint-disable-next-line no-unused-vars
    function isValidUUID(uuid) {
      return /^[\da-z]{25}$/.test(uuid);
    }

    function getColorBitmask() {
      let mask = 'a';
      if (typeof getLocalStorage('col') !== 'undefined') {
        try {
          const excluded = JSON.parse(getLocalStorage('col'));
          for (let i = 0; i < colorPalette.length; i++) {
            mask += excluded.indexOf(colorPalette[i]) === -1 ? '1' : '0';
          }
        } catch (e) {}
      }
      return mask;
    }

    // Mirrors getColorBitmask()'s notion of "selected colors" (colorPalette
    // entries not present in the 'col' exclusion list, in palette order) to
    // answer a different question: what color would this player spawn as
    // right now? Custom color (if enabled) always wins. Otherwise walk the
    // selected colors in order and take the first one not already used by a
    // player in this client's current match — same idea as the server-side
    // spawn assignment, evaluated locally against whatever match state this
    // client can see. Used by the P2P chat mod so each name in chat is
    // colored the way that player would actually appear in a game.
    function getOwnChatColor() {
      const isCustomEnabled = getLocalStorage('ecc') === 'true';
      const customCol = getLocalStorage('ccol');
      if (isCustomEnabled && customCol) return customCol;

      let selected = colorPalette;
      const rawExcluded = getLocalStorage('col');
      if (typeof rawExcluded !== 'undefined') {
        try {
          const excluded = JSON.parse(rawExcluded);
          if (Array.isArray(excluded)) {
            selected = colorPalette.filter(function (c) {
              return excluded.indexOf(c) === -1;
            });
          }
        } catch (e) {}
      }
      if (selected.length === 0) selected = colorPalette;

      const takenColors = players.map(function (p) {
        return p.c;
      });
      for (let i = 0; i < selected.length; i++) {
        if (takenColors.indexOf(selected[i]) === -1) return selected[i];
      }
      return selected[0]; // everything selected is taken — fall back to first choice
    }

    function formatTime(totalSeconds) {
      const h = Math.floor(totalSeconds / 3600);
      let m = Math.floor((totalSeconds / 60) % 60);
      let s = Math.floor(totalSeconds % 60);
      m = m < 10 ? '0' + m : m;
      s = s < 10 ? '0' + s : s;
