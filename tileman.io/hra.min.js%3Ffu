            // direction a P2P-protected player's trail or head?
            let nx = x,
              ny = y;
            if (d === 0) nx = Math.floor(x + 1.001);
            else if (d === 1) ny = Math.floor(y + 1.001);
            else if (d === 2) nx = Math.ceil(x - 1.001);
            else if (d === 3) ny = Math.ceil(y - 1.001);
