          // ── Path length label at midpoint tile ────────────────────────
          if (path.length > 2) {
            var mid    = path[Math.floor(path.length / 2)]
            var labelX = mid[0] * 10 + 5
            var labelY = mid[1] * 10 + 5
            var hops   = (path.length - 1).toString()

            ctx.save()
