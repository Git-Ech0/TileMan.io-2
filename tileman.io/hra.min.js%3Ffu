          var cur = queue[qHead++];

          if (cur.x === tx && cur.y === ty) {
            foundNode = cur;
            break;
          }

          for (var i = 0; i < 4; i++) {
            var dinfo = DIRS[i];

            if (cur.parent === null && localPlayer.d !== 4) {
