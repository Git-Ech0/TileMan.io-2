        hm.get('pan').set({ direction: Hammer.DIRECTION_ALL, threshold: 20 });
        hm.get('swipe').set({ direction: Hammer.DIRECTION_ALL, velocity: 0.001 });
        hm.on('tap', function (e) {
          if (e.srcEvent) {
            const bounds = mobileDirectionContainer.getBoundingClientRect();
            if (
              e.srcEvent.clientX >= bounds.left &&
              e.srcEvent.clientX <= bounds.right &&
              e.srcEvent.clientY >= bounds.top &&
              e.srcEvent.clientY <= bounds.bottom
            )
              return;
          }
          changeDirection(4);
        });
        hm.on('pan', function (e) {
          if (Math.abs(e.velocityX) > Math.abs(e.velocityY)) {
            if (e.velocityX < -0.3) changeDirection(2);
            else if (e.velocityX > 0.3) changeDirection(0);
          } else {
            if (e.velocityY < -0.3) changeDirection(3);
            else if (e.velocityY > 0.3) changeDirection(1);
          }
        });
