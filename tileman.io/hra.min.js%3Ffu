      if (!colorToClear || colorToClear === DEFAULT_EMPTY_CELL_COLOR) return;

      const cleanColor = String(colorToClear).toLowerCase();

      // Safety 1: Permanent self-protection using persistent tracker
      if (!force && lastAssignedSelfColor) {
        const selfColor = String(lastAssignedSelfColor).toLowerCase();
        if (cleanColor === selfColor) {
          return; // Strictly protect your territory from all sweeps
