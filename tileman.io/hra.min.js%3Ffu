        out = [];
      if (!gridMatrix || !gridSize) return out;
      for (let x = 0; x < gridSize; x++) {
        const col = gridMatrix[x];
        if (!col) continue;
        for (let y = 0; y < gridSize; y++) {
          const changedAt = col[y].t;
          if (changedAt !== null && now - changedAt <= 450) {
            out.push([x, y, now - changedAt]);
          }
        }
      }
      return out;
    }

