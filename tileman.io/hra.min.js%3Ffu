      getClosestOwnedTile() {
        if (!localPlayer) return null;
        const px = Math.floor(localPlayer.pos[0]);
        const py = Math.floor(localPlayer.pos[1]);
        const myColor = localPlayer.c;
        const myActiveColor = activeColorPalette[myColor] || myColor;

        const queue = [[px, py, 0]];
        let qHead = 0;
        const visited = new Set([px + ',' + py]);
        const DIRS = [
          [1, 0],
          [-1, 0],
          [0, 1],
          [0, -1],
