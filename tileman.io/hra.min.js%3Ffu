      const x0 = Math.floor(from[0]),
        y0 = Math.floor(from[1]);
      const x1 = Math.floor(player.pos[0]),
        y1 = Math.floor(player.pos[1]);
      const dx = Math.sign(x1 - x0),
        dy = Math.sign(y1 - y0);
      let cx = x0,
        cy = y0;
      const steps = Math.abs(x1 - x0) + Math.abs(y1 - y0);
      for (let s = 0; s <= steps; s++) {
        visit(cx, cy);
        if (cx === x1 && cy === y1) break;
        cx += dx;
        cy += dy;
      }
    }

    function buildOtherPlayerHazardCellSet() {
      const set = new Set();
      const protectedKeys = getP2PProtectedKeySet();
      if (protectedKeys.size === 0) return set;

      for (let i = 0; i < players.length; i++) {
        const p = players[i];
        if (p.m || p.de !== null) continue; // skip local player and dead players
        if (!isP2PProtected(p, protectedKeys)) continue; // not P2P-linked, not protected

        const trs = p.trs;
        if (trs && trs.length >= 2 && !isTrailStale(p)) {
          for (let j = 0; j < trs.length - 1; j++) {
            const x0 = Math.floor(trs[j][0]),
              y0 = Math.floor(trs[j][1]);
            const x1 = Math.floor(trs[j + 1][0]),
              y1 = Math.floor(trs[j + 1][1]);
            const dx = Math.sign(x1 - x0),
              dy = Math.sign(y1 - y0);
            let cx = x0,
              cy = y0;
            const steps = Math.abs(x1 - x0) + Math.abs(y1 - y0);
            for (let s = 0; s <= steps; s++) {
              if (!isOwnedTerritoryTile(p, cx, cy)) set.add(cx + ',' + cy);
              if (cx === x1 && cy === y1) break;
              cx += dx;
              cy += dy;
            }
          }

          // FIX: trs only stores confirmed server turn points — the live
          // in-progress segment from the last turn to the current head is
          // NEVER written into trs while the player is still moving straight.
          // That entire stretch was completely invisible to the hazard set,
          // which is why safety worked fine when the teammate was paused
          // (trs turn points still exist) but did nothing while they moved
          // (the growing live segment has no representation anywhere).
          // Rasterize that missing segment explicitly here: last trs vertex
          // → current head pos, same territory-filter as every other segment.
          const lastVert = trs[trs.length - 1];
          const lx0 = Math.floor(lastVert[0]),
            ly0 = Math.floor(lastVert[1]);
          const lx1 = Math.floor(p.pos[0]),
            ly1 = Math.floor(p.pos[1]);
          const ldx = Math.sign(lx1 - lx0),
            ldy = Math.sign(ly1 - ly0);
          let lcx = lx0,
            lcy = ly0;
          const lsteps = Math.abs(lx1 - lx0) + Math.abs(ly1 - ly0);
          for (let s = 0; s <= lsteps; s++) {
            if (!isOwnedTerritoryTile(p, lcx, lcy)) set.add(lcx + ',' + lcy);
            if (lcx === lx1 && lcy === ly1) break;
            lcx += ldx;
            lcy += ldy;
          }
        }

        // Head tile — always a hazard, unconditionally (see note above).
        // Swept across whatever ground this player covered this frame
        // (see rasterizeHeadSweep) instead of sampled at a single point,
        // so a fast mover can't tunnel through unseen.
        rasterizeHeadSweep(p, function (cx, cy) {
          set.add(cx + ',' + cy);
        });
      }
      return set;
    }


    // Walks the axis-aligned hop from (x0,y0) to (x1,y1) — exactly the kind
    // of hop the look-ahead predictor already projects between simulated
    // turns — and reports whether any tile it *newly enters* is in the
    // trail-cell set. Deliberately does NOT check (x0,y0) itself: that's
    // wherever this leg starts from, which for the first simulated leg is
    // the player's actual current tile — e.g. the pivot point of the turn
    // they just made, now a legitimate endpoint of their own most recent
    // trail segment. Standing there isn't a crash; only moving into a new
    // trail cell is. Every cell a multi-leg simulation actually enters
    // still gets checked exactly once, since each leg's destination
    // (x1,y1) is checked here and becomes the next leg's (now-skipped)
    // starting point.
    function segmentCrossesTrailCells(x0, y0, x1, y1, cellSet) {
      if (cellSet.size === 0) return false;
      // Tile indexing here MUST match pfTrailCells() (both floor-based),
      // since x0/y0 for the first simulated leg is the
      // player's real, fractional position. Math.round() used to disagree
      // with that convention for any fractional position past the half-tile
      // mark: moving toward +x/+y it rounded the start UP to the same tile
      // as the destination (steps came out 0, so a real trail cell one tile
      // ahead was never checked at all); moving toward -x/-y it rounded the
      // start UP past the player's actual current tile, so the destination
      // check landed on the tile the player was still standing in — a tile
      // that's only "trail" because it hasn't been left yet, not because
      // anything was actually crossed. Math.floor keeps the start point
      // pinned to the tile the player is really in, so neither happens.
      const dx = Math.sign(x1 - x0),
        dy = Math.sign(y1 - y0);
      let cx = Math.floor(x0),
        cy = Math.floor(y0);
      const tx = Math.floor(x1),
        ty = Math.floor(y1);
      const steps = Math.abs(tx - cx) + Math.abs(ty - cy);
      for (let s = 1; s <= steps; s++) {
        cx += dx;
        cy += dy;
        if (cellSet.has(cx + ',' + cy)) return true;
        if (cx === tx && cy === ty) break;
      }
      return false;
    }

    function changeDirection(heading) {
