            cy = cur[1],
            dist = cur[2];

          if (gridMatrix[cx] && gridMatrix[cx][cy]) {
            const cellColor = gridMatrix[cx][cy].c;
            if (cellColor === myColor || cellColor === myActiveColor) {
              return { x: cx, y: cy, distance: dist };
            }
          }

          if (dist > 150) continue;

          for (let i = 0; i < 4; i++) {
            const nx = cx + DIRS[i][0];
            const ny = cy + DIRS[i][1];
            if (nx >= 0 && ny >= 0 && nx < gridSize && ny < gridSize) {
              const key = nx + ',' + ny;
              if (!visited.has(key)) {
                visited.add(key);
                queue.push([nx, ny, dist + 1]);
              }
            }
          }
        }
        return null;
      },
      _subs: [],
      subscribe(fn) {
        this._subs.push(fn);
        return function () {
          window.TamState._subs = window.TamState._subs.filter(function (s) {
            return s !== fn;
          });
        };
      },
      _tick() {
        for (let i = 0; i < this._subs.length; i++) {
          try {
            this._subs[i](this);
          } catch (e) {}
        }
      },
    };

    // ═══════════════════════════════════════════════════════════════════════
    //  PATHFINDING ENGINE — Enemy-to-nearest-own-tile BFS overlay
    //  Draws filled tile highlights along the shortest safe path from each
    //  visible enemy head to the nearest tile owned by the local player.
    //
    //  Barriers: local player trail cells, all other live player heads that
    //  are NOT on territory owned by the pathing enemy or themselves, and
    //  the trail cells of all other players.  Grid edges are hard walls.
    //
    //  Rendering: drawn on the SAME canvas in world-space (10px-per-tile)
    //  using the same camera transform, so tiles align perfectly.
    // ═══════════════════════════════════════════════════════════════════════
    (function initPathfindingEngine() {
      // ── Config ────────────────────────────────────────────────────────────
      const PF = {
        RECALC_MS: 90, // how often to re-run BFS (ms)
        BFS_MAX_HOPS: 800, // max BFS expansion before giving up
        PATH_ALPHA: 0.38, // fill alpha for path tiles
        HEAD_ALPHA: 0.7, // ring alpha for enemy head highlight
        TARGET_ALPHA: 0.6, // fill alpha for target tile highlight
        RING_TILES: 0.55, // ring radius as fraction of tile size (10px)
        COLORS: [
          // one color per enemy (cycles)
          '#ff4455',
          '#ff9500',
          '#ffee00',
          '#44ff99',
          '#00d4ff',
          '#cc44ff',
          '#ff44cc',
          '#44ffff',
        ],
      };

      // ── State ─────────────────────────────────────────────────────────────
      let pfLastCalc = 0;
      let pfResults = []; // [{path:[[x,y],...], target:[x,y], player:p, color:'#...'}, ...]

      let pfSelfPath = [];

      window.TamState.forcePathRecalc = function () {
        pfLastCalc = 0;
      };

      // Calculates the exact integer tile the player is committed to landing on based on current velocity
      function getCommittedTile() {
        if (!localPlayer) return null;
        const cx = localPlayer.pos[0];
        const cy = localPlayer.pos[1];
        const d = localPlayer.d;
        const eps = 0.0001;

        let ix = Math.floor(cx);
        let iy = Math.floor(cy);

        if (d === 0 && cx - Math.floor(cx) > eps) ix += 1;
        if (d === 1 && cy - Math.floor(cy) > eps) iy += 1;
        if (d === 2 && Math.ceil(cx) - cx > eps) ix = Math.ceil(cx) - 1;
        if (d === 3 && Math.ceil(cy) - cy > eps) iy = Math.ceil(cy) - 1;

        return { x: ix, y: iy };
      }

      function getClosestEnemy() {
        if (!localPlayer) return null;
        let best = null,
          bestDist = Infinity;
        for (let i = 0; i < players.length; i++) {
          const p = players[i];
          if (p.m || p.de !== null) continue;
          const d =
            Math.abs(p.pos[0] - localPlayer.pos[0]) + Math.abs(p.pos[1] - localPlayer.pos[1]);
          if (d < bestDist) {
            bestDist = d;
            best = p;
          }
        }
        return best;
      }

      function computeOutFlags(path) {
        const flags = [];
        let runningOut = 0;
        for (let i = 0; i < path.length; i++) {
          const owned = isTileOwned(path[i][0], path[i][1]);
          runningOut = owned ? 0 : runningOut + 1;
          flags.push(runningOut);
        }
        return flags;
      }

      function findFirstUnsafeTrailTile(path) {
        const enemy = getClosestEnemy();
        if (!enemy) return null; // nothing to be worried about

        const outFlags = computeOutFlags(path);

        for (let i = 0; i < path.length; i++) {
          if (outFlags[i] === 0) continue; // on owned tile, no trail exposure here

          // hops forward along THIS path until it's back on owned territory
          let stepsUntilReturn = path.length - 1 - i; // fallback if it never returns
          for (let j = i + 1; j < path.length; j++) {
            if (outFlags[j] === 0) {
              stepsUntilReturn = j - i;
              break;
            }
          }

          if (enemyStepsToTile(enemy, path[i][0], path[i][1]) <= stepsUntilReturn) {
            return path[i]; // enemy can beat us back — this trail tile is unsafe
          }
        }
        return null;
      }

      function enemyStepsToTile(enemy, tx, ty) {
        return Math.abs(enemy.pos[0] - tx) + Math.abs(enemy.pos[1] - ty);
      }

      // isTileOwned is called for every neighbor expanded during pathfinding
      // BFS (up to PF.BFS_MAX_HOPS tiles per enemy, per recalc cycle), so the
      // local player's own-color strings — which only change when the player
      // changes color, not per-call — are memoized here rather than being
      // re-derived with toLowerCase()/palette lookups on every tile check.
      let ownColorCacheSource = null;
      let ownColorLower = '';
      let ownActiveColorLower = '';

      function isTileOwned(x, y) {
        if (!localPlayer || x < 0 || y < 0 || x >= gridSize || y >= gridSize) return false;
        const cell = gridMatrix[x] && gridMatrix[x][y];
        if (!cell) return false;

        if (localPlayer.c !== ownColorCacheSource) {
          ownColorCacheSource = localPlayer.c;
          ownColorLower = String(localPlayer.c).toLowerCase();
          ownActiveColorLower = String(
            activeColorPalette[localPlayer.c] || localPlayer.c
          ).toLowerCase();
        }

        // CRITICAL FIX: Case-insensitive color matching so it actually recognizes your territory
        const cellColor = String(cell.c).toLowerCase();
        return cellColor === ownColorLower || cellColor === ownActiveColorLower;
      }

      function getTheSpot() {
        if (!localPlayer) return null;
        if (pfResults && pfResults.length > 0) {
          let best = pfResults[0];
          for (let i = 1; i < pfResults.length; i++) {
            if (pfResults[i].path.length < best.path.length) best = pfResults[i];
          }
          return best.target;
        }
        return null;
      }

      function findSafePathToTargetRaw(tx, ty, extraBarriers) {
        const start = getCommittedTile();
        if (!start) return null;

        if (start.x === tx && start.y === ty) {
          return [[start.x, start.y]];
        }

        const queue = [
          { x: start.x, y: start.y, parent: null, out: isTileOwned(start.x, start.y) ? 0 : 1 },
        ];
        let qHead = 0;

        const visited = new Map();
        visited.set(start.x + start.y * gridSize, queue[0].out);

        const DIRS = [
          { dx: 1, dy: 0, dir: 0 },
          { dx: 0, dy: 1, dir: 1 },
          { dx: -1, dy: 0, dir: 2 },
          { dx: 0, dy: -1, dir: 3 },
        ];

        let foundNode = null;

        while (qHead < queue.length) {
          const cur = queue[qHead++];

          if (cur.x === tx && cur.y === ty) {
            foundNode = cur;
            break;
          }

          for (let i = 0; i < 4; i++) {
            const dinfo = DIRS[i];

            if (cur.parent === null && localPlayer.d !== 4) {
              if (
                (localPlayer.d === 0 && dinfo.dir === 2) ||
                (localPlayer.d === 2 && dinfo.dir === 0) ||
                (localPlayer.d === 1 && dinfo.dir === 3) ||
                (localPlayer.d === 3 && dinfo.dir === 1)
              ) {
                continue;
              }
            }

            const nx = cur.x + dinfo.dx;
            const ny = cur.y + dinfo.dy;

            if (nx >= 0 && ny >= 0 && nx < gridSize && ny < gridSize) {
              if (extraBarriers && extraBarriers.has(nx + ',' + ny)) continue;
              const nextOwned = isTileOwned(nx, ny);
              const nextOut = nextOwned ? 0 : cur.out + 1;

              if (nextOut <= 2) {
                const index = nx + ny * gridSize;
                const prevOut = visited.get(index);

                if (prevOut === undefined || nextOut < prevOut) {
                  visited.set(index, nextOut);
                  queue.push({
                    x: nx,
                    y: ny,
                    parent: cur,
                    out: nextOut,
                  });
                }
              }
            }
          }
        }

        if (foundNode) {
          const path = [];
          let curr = foundNode;
          while (curr !== null) {
            path.push([curr.x, curr.y]);
            curr = curr.parent;
          }
          return path.reverse();
        }
        return null;
      }

      function findSafePathToTarget(tx, ty) {
        const extraBarriers = new Set();
        for (let attempt = 0; attempt < 4; attempt++) {
          const path = findSafePathToTargetRaw(tx, ty, extraBarriers);
          if (!path) return null;
          const risky = findFirstUnsafeTrailTile(path);
          if (!risky) return path;
          extraBarriers.add(risky[0] + ',' + risky[1]);
        }
        return null; // every route we tried can be cut off before we'd get home — stand down
      }
      // ── Coordinate transform ──────────────────────────────────────────────
      // Replicates applyCameraTransform math so we can convert tile → screen px
      // WITHOUT actually setting the canvas transform (we draw in world-space
      // during _tick which fires after ctx.restore(), so we re-apply ourselves).
      function pfGetZoom() {
        const w = canvas.width,
          h = canvas.height;
        const maxDim = Math.max(w, h);
        const scaleA = maxDim / 430;
        let idealWidth;
        if (isLayoutHorizontal) {
          idealWidth = 1100 * Math.min(1, (w * 0.5625) / h);
        } else {
          idealWidth = 1100 * Math.min(1, (h * 0.5625) / w);
        }
        const area = w * h;
        const scaleB = Math.sqrt(area / idealWidth) / 10;
        const zoomFactor = isCameraZoomEnabled ? cameraZoomFactor : 1.0;
        return Math.max(scaleB, scaleA) * zoomFactor;
      }

      // Convert world tile coord (tx, ty) → canvas pixel (screen) [sx, sy]
      // Mirrors: ctx.translate(cw/2, ch/2) → scale(flip*zoom, zoom)
      //          → translate2(-lpt[0]*10-5-off[0], -lpt[1]*10-5-off[1])
      // For horizontal layout translate2 == translate (no swap)
      // For vertical layout translate2 == translate3 (x,y swapped in output)
      // eslint-disable-next-line no-unused-vars
      function pfTileToCanvas(tx, ty) {
        const zoom = pfGetZoom();
        const flip = isLayoutHorizontal ? 1 : -1;
        const cw = canvas.width,
          ch = canvas.height;
        // world-space pixel coords of tile top-left (game uses gx*10, gy*10)
        const wx = tx * 10;
        const wy = ty * 10;
        // apply camera translate2 offset
        const ox = -localPlayerTarget[0] * 10 - 5 - cameraOffsetXY[0];
        const oy = -localPlayerTarget[1] * 10 - 5 - cameraOffsetXY[1];
        if (isLayoutHorizontal) {
          // translate2 = translate: args are (x-offset, y-offset)
          return [cw / 2 + flip * zoom * (wx + ox), ch / 2 + zoom * (wy + oy)];
        } else {
          // translate2 = translate3: function(ox,oy){translate(oy,ox)}
          // so the actual canvas translate is (oy, ox) — y and x swapped
          return [cw / 2 + flip * zoom * (wy + oy), ch / 2 + zoom * (wx + ox)];
        }
      }

      // Tile size in canvas pixels
      // eslint-disable-next-line no-unused-vars
      function pfTilePx() {
        return pfGetZoom() * 10;
      }

      // ── Trail rasterizer ─────────────────────────────────────────────────
      // Walks the trs vertex array and returns integer tile [x,y] pairs
      // that the polyline passes through.
      function pfTrailCells(trs) {
        const out = [];
        if (!trs || trs.length < 2) return out;
        for (let i = 0; i < trs.length - 1; i++) {
          pfRasterSeg(trs[i][0], trs[i][1], trs[i + 1][0], trs[i + 1][1], out);
        }
        return out;
      }

      function pfRasterSeg(x0, y0, x1, y1, out) {
        const ix0 = Math.floor(x0),
          iy0 = Math.floor(y0);
        const ix1 = Math.floor(x1),
          iy1 = Math.floor(y1);
        const dx = Math.sign(ix1 - ix0);
        const dy = Math.sign(iy1 - iy0);
        let cx = ix0,
          cy = iy0;
        const lim = Math.abs(ix1 - ix0) + Math.abs(iy1 - iy0) + 1;
        for (let i = 0; i < lim; i++) {
          if (cx >= 0 && cy >= 0 && cx < gridSize && cy < gridSize) {
            out.push([cx, cy]);
          }
          if (cx === ix1 && cy === iy1) break;
          cx += dx;
          cy += dy;
        }
      }

      // ── Build barrier set for a specific enemy ────────────────────────────
      // Barriers:
      //   1. Local player's trail cells
      //   2. The pathing enemy's OWN trail cells
      //   3. Every OTHER live player's head (not on safe territory)
      //   NOTE: other players' trails are NOT barriers — enemies walk through them freely.
      function pfBarriers(forEnemy) {
        const b = new Set();
        const gs = gridSize;
        const gm = gridMatrix;

        // ── Pathing enemy's own trail ─────────────────────────────────────
        if (forEnemy.trs && forEnemy.trs.length > 0) {
          const etc = pfTrailCells(forEnemy.trs);
          for (let i = 0; i < etc.length; i++) {
            b.add(etc[i][0] + ',' + etc[i][1]);
          }
        }

        // ── Local player head ─────────────────────────────────────────────
        if (localPlayer && localPlayer.de === null) {
          const lhx = Math.floor(localPlayer.pos[0]);
          const lhy = Math.floor(localPlayer.pos[1]);
          if (lhx >= 0 && lhy >= 0 && lhx < gs && lhy < gs) {
            const lhCell = gm[lhx] && gm[lhx][lhy];
            const lhColor = lhCell ? lhCell.c : null;
            const lhNoTerr = lhColor === null || lhColor === DEFAULT_EMPTY_CELL_COLOR;
            const lhForeign = !lhNoTerr && lhColor !== localPlayer.c && lhColor !== forEnemy.c;
            if (lhNoTerr || lhForeign) {
              b.add(lhx + ',' + lhy);
            }
          }
        }

        // ── Other live player heads only (trails ignored) ─────────────────
        for (let pi = 0; pi < players.length; pi++) {
          const p = players[pi];
          if (p.m) continue; // skip local player
          if (p.de !== null) continue; // skip dead
          if (p === forEnemy) continue; // skip the enemy we're pathing for

          const hx = Math.floor(p.pos[0]);
          const hy = Math.floor(p.pos[1]);
          if (hx < 0 || hy < 0 || hx >= gs || hy >= gs) continue;

          const headCell = gm[hx] && gm[hx][hy];
          const headColor = headCell ? headCell.c : null;
          // Compare raw color strings — gridMatrix stores raw player.c values
          const noTerritory = headColor === null || headColor === DEFAULT_EMPTY_CELL_COLOR;
          const foreignTerritory = !noTerritory && headColor !== p.c && headColor !== forEnemy.c;
          if (noTerritory || foreignTerritory) {
            b.add(hx + ',' + hy);
          }
        }

        return b;
      }

      // ── BFS ──────────────────────────────────────────────────────────────
      // Returns {path:[[x,y],...], target:[x,y]} or null
      // path[0] = enemy head tile, path[last] = nearest owned tile
      function pfBFS(sx, sy, barriers) {
        const isx = Math.floor(sx),
          isy = Math.floor(sy);
        if (isx < 0 || isy < 0 || isx >= gridSize || isy >= gridSize) return null;

        // Trivial: already on an owned tile
        if (isTileOwned(isx, isy)) return { path: [[isx, isy]], target: [isx, isy] };

        const queue = [{ x: isx, y: isy, parent: null }];
        let qHead = 0;
        const visited = new Set([isx + isy * gridSize]);
        const DIRS = [
          [1, 0],
          [-1, 0],
          [0, 1],
          [0, -1],
        ];

        while (qHead < queue.length) {
          const cur = queue[qHead++];
          if (qHead >= PF.BFS_MAX_HOPS) break;

          for (let di = 0; di < 4; di++) {
            const nx = cur.x + DIRS[di][0];
            const ny = cur.y + DIRS[di][1];
            if (nx < 0 || ny < 0 || nx >= gridSize || ny >= gridSize) continue;

            const index = nx + ny * gridSize;
            const stringKey = nx + ',' + ny; // barriers still uses string keys
            if (visited.has(index) || barriers.has(stringKey)) continue;
            visited.add(index);

            const nextNode = { x: nx, y: ny, parent: cur };

            if (isTileOwned(nx, ny)) {
              const path = [];
              let curr = nextNode;
              while (curr) {
                path.push([curr.x, curr.y]);
                curr = curr.parent;
              }
              return { path: path.reverse(), target: [nx, ny] };
            }

            queue.push(nextNode);
          }
        }
        return null;
      }

      // ── Recalculate all enemy paths ───────────────────────────────────────
      function pfRecalc() {
        pfResults = [];
        if (!isGameActive || !localPlayer || localPlayer.de !== null) return;
        if (finalScore === 0) return;

        let colorIdx = 0;

        for (let pi = 0; pi < players.length; pi++) {
          const p = players[pi];
          if (p.m || p.de !== null) continue;

          // Only process enemies roughly visible on screen
          const dx = Math.abs(p.pos[0] - cameraPos[0]);
          const dy = Math.abs(p.pos[1] - cameraPos[1]);
          if (dx > cameraWidthDelta + 4 || dy > cameraHeightDelta + 4) continue;

          const barriers = pfBarriers(p);
          const result = pfBFS(p.pos[0], p.pos[1], barriers);

          if (result) {
            pfResults.push({
              path: result.path,
              target: result.target,
              player: p,
              color: PF.COLORS[colorIdx % PF.COLORS.length],
            });
            colorIdx++;
          }
        }
        const spot = getTheSpot();
        pfSelfPath = spot ? findSafePathToTarget(spot[0], spot[1]) || [] : [];
        window.TamState.pfSelfPath = pfSelfPath;
        window.TamState.pfResults = pfResults.map(function (r) {
          return {
            path: r.path,
            target: r.target,
            playerId: r.player ? r.player.id : null,
            playerPos: r.player ? [r.player.pos[0], r.player.pos[1]] : null,
            color: r.color,
          };
        });
      }

      // ── Draw one filled rounded tile rect in world-space px ───────────────
      // Draws on ctx which already has the camera transform applied.
      // (We call this from within the _tick hook after re-applying transform.)
      // eslint-disable-next-line no-unused-vars
      function pfFillTile(pfCtx, tx, ty, tilePx, color, alpha, pad) {
        pad = pad || 0;
        pfCtx.globalAlpha = alpha;
        pfCtx.fillStyle = color;
        const wx = tx * 10 + pad;
        const wy = ty * 10 + pad;
        const sz = 10 - pad * 2;
        pfCtx.fillRect(wx, wy, sz, sz);
      }

      // ── Draw outline rect for target tile ─────────────────────────────────
      function pfStrokeTile(pfCtx, tx, ty, color, alpha, lw) {
        pfCtx.globalAlpha = alpha;
        pfCtx.strokeStyle = color;
        pfCtx.lineWidth = lw;
        pfCtx.strokeRect(tx * 10 + lw / 2, ty * 10 + lw / 2, 10 - lw, 10 - lw);
      }

      // ── Draw enemy head ring (world-space circle) ─────────────────────────
      function pfDrawHead(pfCtx, px, py, color, pulse) {
        const cx = px * 10 + 5;
        const cy = py * 10 + 5;
        const r = 5 * PF.RING_TILES * (0.85 + 0.15 * pulse);
        pfCtx.globalAlpha = PF.HEAD_ALPHA * pulse;
        pfCtx.strokeStyle = color;
        pfCtx.lineWidth = 1.4;
        pfCtx.beginPath();
        pfCtx.arc(cx, cy, r, 0, Math.PI * 2);
        pfCtx.stroke();

        // Inner soft fill
        pfCtx.globalAlpha = 0.25 * pulse;
        pfCtx.fillStyle = color;
        pfCtx.beginPath();
        pfCtx.arc(cx, cy, r * 0.45, 0, Math.PI * 2);
        pfCtx.fill();
      }

      // ── Subscribe to _tick — fires each frame inside renderLoop ───────────
      // _tick is called AFTER ctx.restore(), so we re-apply the camera
      // transform ourselves for world-space drawing, then restore again.
      // Reference speed used to calibrate PF.RECALC_MS (tiles/ms, "standard" mode).
      // serverSpeed is fractional (typ. 0.006-0.010), so scaling must be a RATIO
      // against a baseline, not a raw divisor — Math.max(1, serverSpeed) always
      // collapsed to 1 because serverSpeed is never >= 1, which silently pinned
      // the recalc interval to 90ms in every gamemode, including Extreme Speed.
      const PF_BASE_SPEED = 0.008;

      window.TamState.subscribe(function pfTick() {
        if (!isPathfindingEnabled) return;
        const now = performance.now();

        // Recalc BFS on interval — scales down as serverSpeed rises above baseline
        const speedRatio = (serverSpeed || PF_BASE_SPEED) / PF_BASE_SPEED;
        const recalcInterval = PF.RECALC_MS / Math.max(1, speedRatio);
        if (now - pfLastCalc > recalcInterval) {
          pfRecalc();
          pfLastCalc = now;
        }

        if (!isGameActive || !localPlayer || pfResults.length === 0) return;

        const pulse = 0.65 + 0.35 * Math.sin(now / 240);

        // Re-apply camera transform so we can draw in tile world-space (px = tile*10)
        ctx.save();
        ctx.setTransform(1, 0, 0, 1, 0, 0); // reset any leftover state first
        const zoom = pfGetZoom();
        const flip = isLayoutHorizontal ? 1 : -1;
        const cw = canvas.width,
          ch = canvas.height;
        ctx.translate(cw / 2, ch / 2);
        ctx.scale(flip * zoom, zoom);
        // translate2 in horizontal = translate(ox,oy); in vertical = translate(oy,ox)
        const ox = -localPlayerTarget[0] * 10 - 5 - cameraOffsetXY[0];
        const oy = -localPlayerTarget[1] * 10 - 5 - cameraOffsetXY[1];
        if (isLayoutHorizontal) {
          ctx.translate(ox, oy);
        } else {
          ctx.translate(oy, ox);
        }

        ctx.lineCap = 'square';
        ctx.lineJoin = 'miter';

        // Draw the local player's safe route (skipping their current tile)
        if (pfSelfPath && pfSelfPath.length > 1) {
          for (let i = 1; i < pfSelfPath.length; i++) {
            // Increased opacity to 0.75 and reduced the tile inset to 0.5 for a bolder, thicker path
            pfFillTile(ctx, pfSelfPath[i][0], pfSelfPath[i][1], 10, '#ff00ff', 0.75, 0.5);
          }
        }

        for (let ri = 0; ri < pfResults.length; ri++) {
          const r = pfResults[ri];
          const path = r.path;
          const target = r.target;
          const p = r.player;
          const color = r.color;

          // ── Draw path tiles (all except head and target) ──────────────
          for (let pi2 = 1; pi2 < path.length - 1; pi2++) {
            pfFillTile(ctx, path[pi2][0], path[pi2][1], 10, color, PF.PATH_ALPHA, 1.5);
          }

          // ── Draw target tile ──────────────────────────────────────────
          const tpulse = 0.55 + 0.45 * Math.sin(now / 300 + 1.5);
          pfFillTile(ctx, target[0], target[1], 10, color, PF.TARGET_ALPHA * tpulse, 0.8);
          pfStrokeTile(ctx, target[0], target[1], '#ffffff', 0.7 * tpulse, 1.2);

          // Crosshair on target
          ctx.globalAlpha = 0.75 * tpulse;
          ctx.strokeStyle = '#ffffff';
          ctx.lineWidth = 0.8;
          const tcx = target[0] * 10 + 5,
            tcy = target[1] * 10 + 5;
          ctx.beginPath();
          ctx.moveTo(tcx - 3, tcy);
          ctx.lineTo(tcx + 3, tcy);
          ctx.moveTo(tcx, tcy - 3);
          ctx.lineTo(tcx, tcy + 3);
          ctx.stroke();

          // ── Draw enemy head tile highlight ────────────────────────────
          // The head tile itself (path[0])
          const hx = path[0][0],
            hy = path[0][1];
          pfFillTile(ctx, hx, hy, 10, color, 0.28 * pulse, 0.5);

          // Ring around the actual fractional player position
          pfDrawHead(ctx, p.pos[0], p.pos[1], color, pulse);

          // ── Path length label at midpoint tile ────────────────────────
          if (path.length > 2) {
            const mid = path[Math.floor(path.length / 2)];
            const labelX = mid[0] * 10 + 5;
            const labelY = mid[1] * 10 + 5;
            const hops = (path.length - 1).toString();

            ctx.save();
            // In portrait mode the ctx is already rotated; font direction follows.
            // We want text upright — for vertical layout we un-rotate locally.
            if (!isLayoutHorizontal) {
              ctx.translate(labelX, labelY);
              ctx.scale(-1, 1);
              ctx.translate(-labelX, -labelY);
            }
            ctx.font = 'bold 4px monospace';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.globalAlpha = 0.85;
            // shadow
            ctx.fillStyle = 'rgba(0,0,0,0.7)';
            ctx.fillText(hops, labelX + 0.3, labelY + 0.3);
            ctx.fillStyle = '#ffffff';
            ctx.fillText(hops, labelX, labelY);
            ctx.restore();
          }
        }

        ctx.globalAlpha = 1;
        ctx.restore();
      });
    })();
    // ═══════════════════════════════════════════════════════════════════════
    //  END PATHFINDING ENGINE
    // ═══════════════════════════════════════════════════════════════════════
  }

  function initSettingsPage() {
    const settingsRegistry = {};
    const paletteContainer = document.getElementById('colors');
    const selectAllColors = document.getElementById('colsel');
    const isLegacyEdge = document.documentMode || /Edge/.test(navigator.userAgent);
    let hasCustomSkinColor = typeof getLocalStorage('sha') !== 'undefined' ||
      typeof getLocalStorage('col') !== 'undefined';

    function registerSetting(key, defaultVal) {
      const el = document.getElementById(key);
      if (!el) return; // Safe guard: Skip if element is missing from HTML
      const evType =
        isLegacyEdge && el.tagName !== 'TEXTAREA' && el.type !== 'text' ? 'change' : 'input';
      el.addEventListener(evType, function () {
        if (typeof defaultVal === 'boolean') {
          setLocalStorage(key, this.checked);
        } else {
          setLocalStorage(key, this.value.trim());
        }
        if (key === 'clg2' || key === 'ecc' || key === 'ccol') {
          refreshColorsDisplay();
        }
        if (key === 'thm') {
          handlePresetThemeChange(this.value);
        }
      });
      settingsRegistry[key] = { elem: el, def: defaultVal };
      syncSettingsElement(key);
    }

    function syncSettingsElement(key, checkFocus) {
      if (!settingsRegistry[key]) return;
      const reg = settingsRegistry[key];
      if (reg.def === true) {
        reg.elem.checked = getLocalStorage(key) != 'false';
      } else if (reg.def === false) {
        reg.elem.checked = getLocalStorage(key) == 'true';
      } else if (getLocalStorage(key) == null) {
        reg.elem.value = reg.def;
      } else if (!checkFocus || document.activeElement !== reg.elem || !document.hasFocus()) {
        reg.elem.value = getLocalStorage(key);
      }
      if (key === 'clg2') {
        refreshColorsDisplay();
      }
    }

    function loadSettingsPalette() {
      if (hasCustomSkinColor) {
        document.getElementById('nosha').style.display = 'none';
      }
      const saved = getLocalStorage('col') == null ? true : JSON.parse(getLocalStorage('col'));
      for (let i = 0; i < colorPaletteCheckboxes.length; i++) {
        (saved === true || saved.indexOf(colorPaletteCheckboxes[i].value) === -1) &&
          (colorPaletteCheckboxes[i].checked = true);
        colorPaletteCheckboxes[i].addEventListener('change', onColorPaletteCheckboxChange);
      }
      saved === true ? (selectAllColors.checked = true) : (selectAllColors.indeterminate = true);
    }

    function refreshColorsDisplay() {
      const labels = document.querySelectorAll('#colors label');
      applyBrightnessToColorPalette();
      for (let i = 0; i < labels.length; i++) {
        const v = labels[i].firstElementChild.value;
        labels[i].style.backgroundColor = activeColorPalette[v];
      }
    }

    function resetSettingKey(key) {
      removeLocalStorage(key);
      syncSettingsElement(key);
    }

    function onColorPaletteCheckboxChange() {
      let allChecked = true;
      let noneChecked = true;
      const excluded = [];
      for (let i = 0; i < colorPaletteCheckboxes.length; i++) {
        if (!colorPaletteCheckboxes[i].checked) {
          allChecked = false;
          excluded.push(colorPaletteCheckboxes[i].value);
        } else {
          noneChecked = false;
        }
      }
      if (noneChecked || allChecked) {
        removeLocalStorage('col');
        selectAllColors.checked = !noneChecked;
        selectAllColors.indeterminate = false;
      } else {
        hasCustomSkinColor &&
          ((selectAllColors.checked = false),
          (selectAllColors.indeterminate = true),
          setLocalStorage('col', JSON.stringify(excluded)));
      }
    }

    function onShareClick(e) {
      const popup = window.open(
        this.href,
        '',
        'width=550,height=420,left=' +
          (screen.width / 2 - 275) +
          ',top=80,scrollbars=yes,resizable=yes'
      );
      const check = setInterval(function () {
        popup.closed &&
          (clearInterval(check),
          (document.getElementById('nosha').style.display = 'none'),
          (hasCustomSkinColor = true));
      }, 500);
      setLocalStorage('sha', true);
      e.preventDefault();
    }

    initTouchLabelFix();
    window.rem = resetSettingKey;
    registerSetting('cs2', '');
    registerSetting('pna', true);
    registerSetting('kmsg', true);
    registerSetting('cm', true);
    registerSetting('rp', false);
    registerSetting('an', true);
    registerSetting('ski', true);
    registerSetting('tb', false);
    registerSetting('clg2', '0');
    registerSetting('bg', DEFAULT_BACKGROUND_COLOR);
    registerSetting('bgwa', '#999999');
    registerSetting('bgem', DEFAULT_EMPTY_CELL_COLOR);
    registerSetting('spa', '1');
    registerSetting('ql', '1');
    registerSetting('camzoom', '0.8');
    registerSetting('cmza', true);
    registerSetting('thm', 'default');
    registerSetting('scrsens', '0.015');
    registerSetting('pfe', false);
    registerSetting('apg', false);
    registerSetting('mmp', false);
    registerSetting('ecc', false);
    registerSetting('ccol', '#ff0000');
    registerSetting('apg_col', '#ffd700');
    registerSetting('ap3_col', '#00ff00');
    registerSetting('ap1_col', '#ff0000');
    registerSetting('p_tab', true);
    registerSetting('s_info', true);
    registerSetting('alw_spc', true);

    document.getElementById('sha1').addEventListener('click', onShareClick);
    document.getElementById('sha2').addEventListener('click', onShareClick);
    document.getElementById('reset_set').addEventListener('click', function () {
      if (confirm('Reset settings to default?')) {
        for (const key in settingsRegistry) {
          settingsRegistry.hasOwnProperty(key) && resetSettingKey(key);
        }
      }
    });
    document.getElementById('reset_score').addEventListener('click', function () {
      if (confirm('Remove high score?')) {
        removeLocalStorage('hs');
      }
    });

    // Nearest-Neighbor Perceptual Sort using CIEDE2000 DeltaE
    let sortedPalette;
    try {
      if (typeof chroma.deltaE !== 'function') {
        throw new Error('chroma.deltaE unavailable');
      }

      const remainingColors = colorPalette.slice(0);
      sortedPalette = [];

      // Start at a logical base (dark red is an excellent anchor)
      const startColor = '#7c0000';
      let startIdx = remainingColors.indexOf(startColor);
      if (startIdx === -1) startIdx = 0;

      let currentHex = remainingColors.splice(startIdx, 1)[0];
      sortedPalette.push(currentHex);

      while (remainingColors.length > 0) {
        let closestIdx = 0;
        let minDistance = Infinity;

        for (let i = 0; i < remainingColors.length; i++) {
          // Calculate perceptual visual difference as seen by the human eye
          const dist = chroma.deltaE(currentHex, remainingColors[i]);
          if (dist < minDistance) {
            minDistance = dist;
            closestIdx = i;
          }
        }

        currentHex = remainingColors.splice(closestIdx, 1)[0];
        sortedPalette.push(currentHex);
      }
    } catch (err) {
      // This chroma.js build doesn't support deltaE (or something else went
      // wrong with the sort) — fall back to the palette's original order so
      // the color grid still renders instead of silently disappearing.
      sortedPalette = colorPalette.slice(0);
    }

    let paletteHtml = '';
    for (let i = 0; i < sortedPalette.length; i++) {
      paletteHtml +=
        '<label style=background-color:' +
        sortedPalette[i] +
        ' class=colorbox><input type=checkbox value=' +
        sortedPalette[i] +
        '></label>';
    }
    paletteContainer.innerHTML = paletteHtml;
    refreshColorsDisplay();
    const colorPaletteCheckboxes = document.querySelectorAll('#colors label input');
    loadSettingsPalette();

    selectAllColors.addEventListener('click', function () {
      const checked = selectAllColors.checked;
      for (let i = 0; i < colorPaletteCheckboxes.length; i++) {
        colorPaletteCheckboxes[i].checked = checked;
      }
      removeLocalStorage('col');
    });

    addEventListener('storage', function (e) {
      if (!isLegacyEdge) {
        syncSettingsElement(e.key, true);
      }
    });
  }

  if (location.pathname === '/settings.html') {
    initSettingsPage();
  } else {
    initGame();
  }
})(window, document, Math, performance);
