          }
        }
      }

      if (!gridMatrix || gridMatrix.length === 0) return;

      const now = performance.now();
      for (let r = 0; r < gridSize; r++) {
        if (!gridMatrix[r]) continue;
        for (let c = 0; c < gridSize; c++) {
          if (gridMatrix[r][c] && gridMatrix[r][c].c) {
            const targetCellColor = String(gridMatrix[r][c].c).toLowerCase();
            if (targetCellColor === cleanColor) {
              gridMatrix[r][c].c = DEFAULT_EMPTY_CELL_COLOR;
              gridMatrix[r][c].t = now;
            }
          }
        }
      }
    }

