    // ═══════════════════════════════════════════════════════════════════════
    //  PATHFINDING ENGINE — Three-channel overlay
    //
    //  Channel A — SELF RETURN PATH (magenta)
    //    BFS from local player head → nearest owned territory tile.
    //    Barriers : own trail cells (wall), grid edges (wall).
    //    Invisible: enemy trails, enemy tiles, enemy territory.
    //    Constraint: first step cannot reverse current direction.
    //
    //  Channel B — ENEMY → LOCAL TERRITORY (per-enemy color)
    //    BFS from each visible enemy head → nearest local-player territory tile.
    //    Barriers : own trail (wall), that enemy's own trail (wall), grid edges (wall).
    //    Invisible: every other enemy's trail, every other territory, enemy's own territory.
    //    (If that enemy ran into local trail, local territory would already be gone, so
    //     local trail being the only wall is the correct model.)
    //
    //  Channel C — ENEMY → LOCAL TRAIL (per-enemy color, dimmer)
    //    BFS from each visible enemy head → nearest local-player TRAIL tile.
    //    Barriers : that enemy's own trail (wall), grid edges (wall).
    //    Invisible: other enemy trails, ALL territory (including local).
    //    Only computed when local player IS building a trail (trs.length > 0).
    //
    //  All three results are exposed on window.TamState for userscripts.
    //  Rendering: world-space tile coords drawn on the shared canvas.
    // ═══════════════════════════════════════════════════════════════════════
    (function initPathfindingEngine() {
      // ── Config ────────────────────────────────────────────────────────────
      const PF = {
        RECALC_MS: 90,       // how often to re-run all BFS channels (ms)
        BFS_MAX_HOPS: 40000, // Expanded to cover full 200x200 map without distance cutoffs
        // Channel A — self return
        SELF_PATH_ALPHA: 0.80,
        SELF_PATH_COLOR: '#ff00ff',
        // Channel B — enemy → local territory
        TERR_PATH_ALPHA: 0.40,
        TERR_TARGET_ALPHA: 0.65,
        TERR_HEAD_ALPHA: 0.72,
        // Channel C — enemy → local trail
        TRAIL_PATH_ALPHA: 0.28,
        TRAIL_TARGET_ALPHA: 0.55,
        TRAIL_TARGET_COLOR: '#ffffff',
        RING_TILES: 0.55,
        COLORS: [
          '#ff4455', '#ff9500', '#ffee00', '#44ff99',
          '#00d4ff', '#cc44ff', '#ff44cc', '#44ffff',
        ],
      };

      // State ─────────────────────────────────────────────────────────────
      let pfLastCalc    = 0;
      // Channel A
      let pfSelfPath    = [];   // [[x,y], ...]  head→territory
      let lastKnownTerritory = [];
      const cachedOwnedTiles = new Set(); // Persistent coordinate memory: Set of "x,y"

      // Sync method to dynamically manage remembered tiles
      function updateCachedOwnedTiles() {
        if (!localPlayer) return;
        const rx = window.pl(22, 1, isArenaResetActive);
        const ry = window.pl(13, 1, isArenaResetActive);

        // Limit viewport checks strictly to active screen bounds
        const minX = Math.max(0, Math.floor(cameraPos[0] - rx));
        const maxX = Math.min(gridSize - 1, Math.ceil(cameraPos[0] + rx));
        const minY = Math.max(0, Math.floor(cameraPos[1] - ry));
        const maxY = Math.min(gridSize - 1, Math.ceil(cameraPos[1] + ry));

        for (let x = minX; x <= maxX; x++) {
          for (let y = minY; y <= maxY; y++) {
            const key = x + ',' + y;
            if (isTileOwned(x, y)) {
              cachedOwnedTiles.add(key);
            } else {
              cachedOwnedTiles.delete(key);
            }
          }
        }
      }

      // Expose clear hook for game restarts
      window.TamState.clearCachedOwnedTiles = function() {
        cachedOwnedTiles.clear();
      };
      // Channel B  enemy→territory
      let pfResults     = [];   // [{path, target, player, color}, ...]
      // Channel C  enemy→trail
      let pfTrailPaths  = [];   // [{path, target, player, color}, ...]

      window.TamState.forcePathRecalc = function () { pfLastCalc = 0; };

      // ── Color helpers (memoised) ──────────────────────────────────────────
      let _ownSrc = null, _ownLo = '', _ownActLo = '';
      function _refreshOwnColors() {
        if (!localPlayer || localPlayer.c === _ownSrc) return;
        _ownSrc   = localPlayer.c;
        _ownLo    = String(localPlayer.c).toLowerCase();
        _ownActLo = String(activeColorPalette[localPlayer.c] || localPlayer.c).toLowerCase();
      }

      // Is (x,y) local-player territory?
      function isTileOwned(x, y) {
        if (!localPlayer || x < 0 || y < 0 || x >= gridSize || y >= gridSize) return false;
        const cell = gridMatrix[x] && gridMatrix[x][y];
        if (!cell) return false;
        _refreshOwnColors();
        const cc = String(cell.c).toLowerCase();
        return cc === _ownLo || cc === _ownActLo;
      }

      function updateLastKnownTerritory() {
        const current = [];
        for (let x = 0; x < gridSize; x++) {
          for (let y = 0; y < gridSize; y++) {
            if (isTileOwned(x, y)) {
              current.push([x, y]);
            }
          }
        }
        if (current.length > 0) {
          lastKnownTerritory = current;
        }
      }

      // Is (x,y) a tile in local-player's LIVE trail?
      // We keep a flat Set<number> built once per recalc rather than re-scanning every BFS call.
      let _selfTrailSet = null;   // Set of (x + y*gridSize)
      let _selfTrailTileList = []; // [[x,y], ...] for target iteration in channel-C BFS

      function _buildSelfTrailSet() {
        _selfTrailSet      = new Set();
        _selfTrailTileList = [];
        if (!localPlayer || !localPlayer.trs || localPlayer.trs.length < 2) return;

        // trs vertices are only appended on direction changes, so pfTrailCells()
        // alone misses the live growing segment: last stored vertex → current pos.
        // We rasterize that segment explicitly and merge it in so Channel-C BFS
        // always reflects the full trail, not just the state at the last turn.
        const cells = pfTrailCells(localPlayer.trs);

        // ── Live growing segment (last trs vertex → player.pos) ──────────────
        const lastVtx = localPlayer.trs[localPlayer.trs.length - 1];
        if (lastVtx) {
          pfRasterSeg(
            lastVtx[0], lastVtx[1],
            localPlayer.pos[0], localPlayer.pos[1],
            cells   // append directly into cells array; deduped by seen Set below
          );
        }

        // Dedup + territory filter in one pass.
        // (pfTrailCells + live segment can overlap at the junction vertex, hence dedup.)
        const seen = new Set();
        for (let i = 0; i < cells.length; i++) {
          const tx = cells[i][0], ty = cells[i][1];
          const key = tx + ty * gridSize;
          if (seen.has(key)) continue;
          seen.add(key);
          // Only count cells that are genuinely trail (not already closed back into territory)
          if (!isTileOwned(tx, ty)) {
            _selfTrailSet.add(key);
            _selfTrailTileList.push([tx, ty]);
          }
        }
      }

      function isTileOnSelfTrail(x, y) {
        return _selfTrailSet !== null && _selfTrailSet.has(x + y * gridSize);
      }

      // ── Committed tile for local player (respects partial-tile movement) ──
      function getCommittedTile() {
        if (!localPlayer) return null;
        const cx = localPlayer.pos[0], cy = localPlayer.pos[1];
        const d  = localPlayer.d;
        const eps = 0.0001;
        let ix = Math.floor(cx), iy = Math.floor(cy);
        if (d === 0 && cx - Math.floor(cx) > eps) ix += 1;
        if (d === 1 && cy - Math.floor(cy) > eps) iy += 1;
        if (d === 2 && Math.ceil(cx) - cx > eps)  ix = Math.ceil(cx) - 1;
        if (d === 3 && Math.ceil(cy) - cy > eps)  iy = Math.ceil(cy) - 1;
        return { x: ix, y: iy };
      }

      // ══════════════════════════════════════════════════════════════════════
      //  CHANNEL A — Self return path
      //  BFS: player head → nearest owned territory tile
      //  Walls   : own trail cells, grid edges
      //  Passable: enemy trails, enemy tiles, enemy territory (all invisible)
      //  Constraint: first step cannot be backwards relative to current heading
      // ══════════════════════════════════════════════════════════════════════
      // Fixed, Fast Return Pathfinder
      function pfSelfReturnFast() {
        if (!localPlayer) return [];
        const start = getCommittedTile();
        if (!start) return [];

        const px = start.x;
        const py = start.y;

        updateCachedOwnedTiles();

        // Standing on owned territory -> home
        if (isTileOwned(px, py)) return [];

        // Build target lookup from cached + active grid tiles
        const targets = new Set(cachedOwnedTiles);
        for (let x = 0; x < gridSize; x++) {
          for (let y = 0; y < gridSize; y++) {
            if (isTileOwned(x, y)) targets.add(x + ',' + y);
          }
        }

        if (targets.size === 0) return [];

        const queue = [{ x: px, y: py, p: null }];
        let head = 0;
        const visited = new Uint8Array(gridSize * gridSize);
        visited[px + py * gridSize] = 1;
        const DIRS = [[1, 0], [-1, 0], [0, 1], [0, -1]];

        while (head < queue.length && head < 8000) {
          const cur = queue[head++];
          const key = cur.x + ',' + cur.y;

          // Target reached (ignoring starting point)
          if ((cur.x !== px || cur.y !== py) && (targets.has(key) || isTileOwned(cur.x, cur.y))) {
            const path = [];
            let c = cur;
            while (c) {
              path.push([c.x, c.y]);
              c = c.p;
            }
            return path.reverse();
          }

          for (let i = 0; i < 4; i++) {
            const nx = cur.x + DIRS[i][0];
            const ny = cur.y + DIRS[i][1];

            if (nx < 0 || ny < 0 || nx >= gridSize || ny >= gridSize) continue;

            const idx = nx + ny * gridSize;
            if (visited[idx] === 1) continue;

            // Do not walk through active trail cells unless owned
            if (isTileOnSelfTrail(nx, ny) && !isTileOwned(nx, ny)) continue;

            visited[idx] = 1;
            queue.push({ x: nx, y: ny, p: cur });
          }
        }

        return [];
      }

      // ══════════════════════════════════════════════════════════════════════
      //  CHANNEL C — Enemy → local trail
      //  BFS: enemy head → nearest local-player trail tile
      //  Walls   : this enemy's own trail cells, grid edges
      //  Passable: other enemy trails (invisible), ALL territory (invisible)
      //  Only runs when local player has an active trail.
      // ══════════════════════════════════════════════════════════════════════
      function pfEnemyToTrailBarriers(enemy) {
        const b = new Set();
        // Only this enemy's own trail is a wall
        if (enemy.trs && enemy.trs.length >= 2) {
          const etc = pfTrailCells(enemy.trs);
          for (let i = 0; i < etc.length; i++) {
            b.add(etc[i][0] + ',' + etc[i][1]);
          }
        }
        return b;
      }

      function pfEnemyToTrailBFS(enemy) {
        if (!_selfTrailTileList || _selfTrailTileList.length === 0) return null;

        const sx = Math.floor(enemy.pos[0]);
        const sy = Math.floor(enemy.pos[1]);
        if (sx < 0 || sy < 0 || sx >= gridSize || sy >= gridSize) return null;

        // Check trivial: enemy already on a trail tile
        if (isTileOnSelfTrail(sx, sy)) return { path: [[sx, sy]], target: [sx, sy] };

        const barriers = pfEnemyToTrailBarriers(enemy);
        const DIRS = [[1,0],[-1,0],[0,1],[0,-1]];
        const queue   = [{ x: sx, y: sy, parent: null }];
        let qHead = 0;
        const visited = new Set([sx + sy * gridSize]);

        while (qHead < queue.length) {
          const cur = queue[qHead++];
          if (qHead > PF.BFS_MAX_HOPS) break;

          for (let di = 0; di < 4; di++) {
            const nx = cur.x + DIRS[di][0];
            const ny = cur.y + DIRS[di][1];
            if (nx < 0 || ny < 0 || nx >= gridSize || ny >= gridSize) continue;

            const idx = nx + ny * gridSize;
            if (visited.has(idx) || barriers.has(nx + ',' + ny)) continue;
            visited.add(idx);

            const node = { x: nx, y: ny, parent: cur };

            if (isTileOnSelfTrail(nx, ny)) {
              const path = [];
              let c = node;
              while (c) { path.push([c.x, c.y]); c = c.parent; }
              return { path: path.reverse(), target: [nx, ny] };
            }

            queue.push(node);
          }
        }
        return null;
      }
      // ── Coordinate transform ──────────────────────────────────────────────
      // Replicates applyCameraTransform math so we can convert tile → screen px
      // WITHOUT actually setting the canvas transform (we draw in world-space
      // during _tick which fires after ctx.restore(), so we re-apply ourselves).
      function pfGetZoom() {
        const w = canvas.width,
          h = canvas.height;
        const maxDim = Math.max(w, h);
        const scaleA = maxDim / 430;
        let idealWidth;
        if (isLayoutHorizontal) {
          idealWidth = 1100 * Math.min(1, (w * 0.5625) / h);
        } else {
          idealWidth = 1100 * Math.min(1, (h * 0.5625) / w);
        }
        const area = w * h;
        const scaleB = Math.sqrt(area / idealWidth) / 10;
        const zoomFactor = isCameraZoomEnabled ? cameraZoomFactor : 1.0;
        return Math.max(scaleB, scaleA) * zoomFactor;
      }

      // Convert world tile coord (tx, ty) → canvas pixel (screen) [sx, sy]
      // Mirrors: ctx.translate(cw/2, ch/2) → scale(flip*zoom, zoom)
      //          → translate2(-lpt[0]*10-5-off[0], -lpt[1]*10-5-off[1])
      // For horizontal layout translate2 == translate (no swap)
      // For vertical layout translate2 == translate3 (x,y swapped in output)
      // eslint-disable-next-line no-unused-vars
      function pfTileToCanvas(tx, ty) {
        const zoom = pfGetZoom();
        const flip = isLayoutHorizontal ? 1 : -1;
        const cw = canvas.width,
          ch = canvas.height;
        // world-space pixel coords of tile top-left (game uses gx*10, gy*10)
        const wx = tx * 10;
        const wy = ty * 10;
        // apply camera translate2 offset
        const ox = -localPlayerTarget[0] * 10 - 5 - cameraOffsetXY[0];
        const oy = -localPlayerTarget[1] * 10 - 5 - cameraOffsetXY[1];
        if (isLayoutHorizontal) {
          // translate2 = translate: args are (x-offset, y-offset)
          return [cw / 2 + flip * zoom * (wx + ox), ch / 2 + zoom * (wy + oy)];
        } else {
          // translate2 = translate3: function(ox,oy){translate(oy,ox)}
          // so the actual canvas translate is (oy, ox) — y and x swapped
          return [cw / 2 + flip * zoom * (wy + oy), ch / 2 + zoom * (wx + ox)];
        }
      }

      // Tile size in canvas pixels
      // eslint-disable-next-line no-unused-vars
      function pfTilePx() {
        return pfGetZoom() * 10;
      }

      // ── Trail rasterizer ─────────────────────────────────────────────────
      // Walks the trs vertex array and returns integer tile [x,y] pairs
      // that the polyline passes through.
      function pfTrailCells(trs) {
        const out = [];
        if (!trs || trs.length < 2) return out;
        for (let i = 0; i < trs.length - 1; i++) {
          pfRasterSeg(trs[i][0], trs[i][1], trs[i + 1][0], trs[i + 1][1], out);
        }
        return out;
      }

      function pfRasterSeg(x0, y0, x1, y1, out) {
        const ix0 = Math.floor(x0),
          iy0 = Math.floor(y0);
        const ix1 = Math.floor(x1),
          iy1 = Math.floor(y1);
        const dx = Math.sign(ix1 - ix0);
        const dy = Math.sign(iy1 - iy0);
        let cx = ix0,
          cy = iy0;
        const lim = Math.abs(ix1 - ix0) + Math.abs(iy1 - iy0) + 1;
        for (let i = 0; i < lim; i++) {
          if (cx >= 0 && cy >= 0 && cx < gridSize && cy < gridSize) {
            out.push([cx, cy]);
          }
          if (cx === ix1 && cy === iy1) break;
          cx += dx;
          cy += dy;
        }
      }

      // ── Recalculate all three channels ────────────────────────────────────
      function pfRecalc() {
        pfResults    = [];
        pfTrailPaths = [];
        pfSelfPath   = [];

        if (!isGameActive || !localPlayer || localPlayer.de !== null) return;

        // Rebuild self-trail Set (used by channels A, B, C)
        _buildSelfTrailSet();

        // ── Channel A — self return path ────────────────────────────────────
        const isStandingOnTerritory = isTileOwned(Math.floor(localPlayer.pos[0]), Math.floor(localPlayer.pos[1]));
        if (isStandingOnTerritory) {
          isNoKillsReturnActive = false; // Turn OFF return mode immediately upon touching territory
        }

        // Calculate return path ONLY during return mode (No Kills) OR when general pathfinding overlay (pfe) is ON
        if (!isStandingOnTerritory && (isPathfindingEnabled || (isNoKillsPathfindingEnabled && isNoKillsReturnActive))) {
          _buildSelfTrailSet();
          pfSelfPath = pfSelfReturnFast();
        }

        // Strictly SKIP all enemy pathfinding calculations if general pathfinding overlay (pfe) is OFF
        if (!isPathfindingEnabled) return;

        // ── Channels B & C — per visible enemy ─────────────────────────────
        const hasSelfTrail = _selfTrailTileList.length > 0;
        let colorIdx = 0;

        for (let pi = 0; pi < players.length; pi++) {
          const p = players[pi];
          if (p.m || p.de !== null) continue; // skip self, skip dead

          // Visibility cull — only enemies visible on screen
          const dx = Math.abs(p.pos[0] - cameraPos[0]);
          const dy = Math.abs(p.pos[1] - cameraPos[1]);
          if (dx > cameraWidthDelta + 4 || dy > cameraHeightDelta + 4) continue;

          const color = PF.COLORS[colorIdx % PF.COLORS.length];
          colorIdx++;

          // Channel B: enemy → local territory (always computed)
          const terrResult = pfEnemyToTerritoryBFS(p);
          if (terrResult) {
            pfResults.push({ path: terrResult.path, target: terrResult.target, player: p, color });
          }

          // Channel C: enemy → local trail (only when we have a live trail)
          if (hasSelfTrail) {
            const trailResult = pfEnemyToTrailBFS(p);
            if (trailResult) {
              pfTrailPaths.push({ path: trailResult.path, target: trailResult.target, player: p, color });
            }
          }
        }

        // ── Expose everything to userscripts via TamState ───────────────────
        window.TamState.pfSelfPath = pfSelfPath;

        window.TamState.pfResults = pfResults.map(function (r) {
          return {
            path:       r.path,
            target:     r.target,
            playerId:   r.player ? r.player.id   : null,
            playerPos:  r.player ? [r.player.pos[0], r.player.pos[1]] : null,
            color:      r.color,
          };
        });

        // New: enemy→trail paths, same schema as pfResults
        window.TamState.pfTrailPaths = pfTrailPaths.map(function (r) {
          return {
            path:       r.path,
            target:     r.target,
            playerId:   r.player ? r.player.id   : null,
            playerPos:  r.player ? [r.player.pos[0], r.player.pos[1]] : null,
            color:      r.color,
          };
        });

        // New: combined snapshot function mirrors getPathfindingSnapshot
        window.TamState.pfSnapshot = {
          selfReturnPath: pfSelfPath,            // Channel A
          enemyToTerritory: window.TamState.pfResults,  // Channel B
          enemyToTrail: window.TamState.pfTrailPaths,   // Channel C
          hasSelfTrail: hasSelfTrail,
          timestamp: performance.now(),
        };
      }

      // ── Draw one filled rounded tile rect in world-space px ───────────────
      // Draws on ctx which already has the camera transform applied.
      // (We call this from within the _tick hook after re-applying transform.)
      // eslint-disable-next-line no-unused-vars
      function pfFillTile(pfCtx, tx, ty, tilePx, color, alpha, pad) {
        pad = pad || 0;
        pfCtx.globalAlpha = alpha;
        pfCtx.fillStyle = color;
        const wx = tx * 10 + pad;
        const wy = ty * 10 + pad;
        const sz = 10 - pad * 2;
        pfCtx.fillRect(wx, wy, sz, sz);
      }

      // ── Draw outline rect for target tile ─────────────────────────────────
      function pfStrokeTile(pfCtx, tx, ty, color, alpha, lw) {
        pfCtx.globalAlpha = alpha;
        pfCtx.strokeStyle = color;
        pfCtx.lineWidth = lw;
        pfCtx.strokeRect(tx * 10 + lw / 2, ty * 10 + lw / 2, 10 - lw, 10 - lw);
      }

      // ── Draw enemy head ring (world-space circle) ─────────────────────────
      function pfDrawHead(pfCtx, px, py, color, pulse) {
        const cx = px * 10 + 5;
        const cy = py * 10 + 5;
        const r = 5 * PF.RING_TILES * (0.85 + 0.15 * pulse);
        pfCtx.globalAlpha = PF.HEAD_ALPHA * pulse;
        pfCtx.strokeStyle = color;
        pfCtx.lineWidth = 1.4;
        pfCtx.beginPath();
        pfCtx.arc(cx, cy, r, 0, Math.PI * 2);
        pfCtx.stroke();

        // Inner soft fill
        pfCtx.globalAlpha = 0.25 * pulse;
        pfCtx.fillStyle = color;
        pfCtx.beginPath();
        pfCtx.arc(cx, cy, r * 0.45, 0, Math.PI * 2);
        pfCtx.fill();
      }

      // ── Hop-count label ───────────────────────────────────────────────────
      // Renders a small text label at world-space tile (tx, ty) centre.
      // Handles portrait-mode un-rotation automatically.
      function pfDrawHopLabel(pfCtx, tx, ty, text) {
        const labelX = tx * 10 + 5;
        const labelY = ty * 10 + 5;
        pfCtx.save();
        if (!isLayoutHorizontal) {
          pfCtx.translate(labelX, labelY);
          pfCtx.scale(-1, 1);
          pfCtx.translate(-labelX, -labelY);
        }
        pfCtx.font         = 'bold 4px monospace';
        pfCtx.textAlign    = 'center';
        pfCtx.textBaseline = 'middle';
        pfCtx.globalAlpha  = 0.85;
        pfCtx.fillStyle    = 'rgba(0,0,0,0.7)';
        pfCtx.fillText(text, labelX + 0.3, labelY + 0.3);
        pfCtx.fillStyle    = '#ffffff';
        pfCtx.fillText(text, labelX, labelY);
        pfCtx.restore();
      }

      // ── Subscribe to _tick — fires each frame inside renderLoop ───────────
      // _tick is called AFTER ctx.restore(), so we re-apply the camera
      // transform ourselves for world-space drawing, then restore again.
      // Reference speed used to calibrate PF.RECALC_MS (tiles/ms, "standard" mode).
      // serverSpeed is fractional (typ. 0.006-0.010), so scaling must be a RATIO
      // against a baseline, not a raw divisor — Math.max(1, serverSpeed) always
      // collapsed to 1 because serverSpeed is never >= 1, which silently pinned
      // the recalc interval to 90ms in every gamemode, including Extreme Speed.
      const PF_BASE_SPEED = 0.008;

      window.TamState.subscribe(function pfTick() {
        if (!isPathfindingEnabled && !isNoKillsPathfindingEnabled) return;
        const now = performance.now();

        // Recalc BFS on interval — scales down as serverSpeed rises above baseline
        const speedRatio = (serverSpeed || PF_BASE_SPEED) / PF_BASE_SPEED;
        const recalcInterval = PF.RECALC_MS / Math.max(1, speedRatio);
        if (now - pfLastCalc > recalcInterval) {
          pfRecalc();
          pfLastCalc = now;
        }

        if (!isGameActive || !localPlayer) return;
        const hasAnything = pfSelfPath.length > 0 || pfResults.length > 0 || pfTrailPaths.length > 0;
        if (!hasAnything) return;

        const pulse  = 0.65 + 0.35 * Math.sin(now / 240);
        const tpulse = 0.55 + 0.45 * Math.sin(now / 300 + 1.5);

        // Re-apply camera transform so we can draw in tile world-space (px = tile*10)
        ctx.save();
        ctx.setTransform(1, 0, 0, 1, 0, 0);
        const zoom = pfGetZoom();
        const flip = isLayoutHorizontal ? 1 : -1;
        const cw = canvas.width, ch = canvas.height;
        ctx.translate(cw / 2, ch / 2);
        ctx.scale(flip * zoom, zoom);
        const ox = -localPlayerTarget[0] * 10 - 5 - cameraOffsetXY[0];
        const oy = -localPlayerTarget[1] * 10 - 5 - cameraOffsetXY[1];
        if (isLayoutHorizontal) { ctx.translate(ox, oy); }
        else                    { ctx.translate(oy, ox); }

        ctx.lineCap  = 'square';
        ctx.lineJoin = 'miter';

        // ── CHANNEL A — Simple Static Radial Tile Path ──────────────────────
        const showSelfPath = isPathfindingEnabled || (isNoKillsPathfindingEnabled && isNoKillsReturnActive);
        if (showSelfPath && pfSelfPath.length > 1) {
          ctx.save();

          // Calculate safety status once for color selection
          let isDeadly = false;
          let timeLeftMs = 0;
          if (respawnCooldownMs !== null && lastRespawnTime !== null) {
            const elapsed = performance.now() - lastRespawnTime;
            timeLeftMs = respawnCooldownMs - elapsed;
            const travelTimeMs = pfSelfPath.length / serverSpeed;
            isDeadly = timeLeftMs < travelTimeMs;
          }

          const pathColor = isDeadly ? 'rgba(255, 68, 68, 0.7)' : 'rgba(0, 229, 255, 0.65)';

          // Static radial gradient per path tile (radiating outward from tile center)
          for (let i = 1; i < pfSelfPath.length; i++) {
            const tx = pfSelfPath[i][0];
            const ty = pfSelfPath[i][1];
            const cx = tx * 10 + 5;
            const cy = ty * 10 + 5;

            const grad = ctx.createRadialGradient(cx, cy, 0, cx, cy, 5.5);
            grad.addColorStop(0, pathColor);
            grad.addColorStop(1, 'rgba(0, 0, 0, 0)');

            ctx.fillStyle = grad;
            ctx.fillRect(tx * 10, ty * 10, 10, 10);
          }

          // Static target dot at destination tile
          const st = pfSelfPath[pfSelfPath.length - 1];
          const tcx = st[0] * 10 + 5;
          const tcy = st[1] * 10 + 5;

          ctx.fillStyle = isDeadly ? '#ff4444' : '#00e5ff';
          ctx.beginPath();
          ctx.arc(tcx, tcy, 2.5, 0, Math.PI * 2);
          ctx.fill();

          ctx.restore();

          // Hop count label on midpoint
          if (pfSelfPath.length > 3) {
            const mid = pfSelfPath[Math.floor(pfSelfPath.length / 2)];
            pfDrawHopLabel(ctx, mid[0], mid[1], (pfSelfPath.length - 1).toString());
          }

          // Draw status overlay text above player head ONLY while returning in No Kills
          if (isNoKillsPathfindingEnabled && isNoKillsReturnActive && respawnCooldownMs !== null && lastRespawnTime !== null) {
            ctx.save();
            const headX = localPlayer.pos[0] * 10 + 5;
            const headY = localPlayer.pos[1] * 10 - 8;

            if (!isLayoutHorizontal) {
              ctx.translate(headX, headY);
              ctx.scale(-1, 1);
              ctx.translate(-headX, -headY);
            }

            ctx.font = 'bold 3.5px sans-serif';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'bottom';
            ctx.fillStyle = isDeadly ? '#ff3333' : '#33ff33';
            ctx.shadowColor = 'black';
            ctx.shadowBlur = 3;

            const txt = isDeadly ? 'DEATH IMMINENT' : 'SAFE (' + Math.ceil(timeLeftMs / 1000) + 's)';
            ctx.fillText(txt, headX, headY);
            ctx.restore();
          }
        }

        // ── CHANNEL B — Enemy → local territory ────────────────────────────
        for (let ri = 0; ri < pfResults.length; ri++) {
          const r      = pfResults[ri];
          const path   = r.path;
          const target = r.target;
          const p      = r.player;
          const color  = r.color;

          // Path body (excluding head tile at [0], excluding target at [last])
          for (let pi2 = 1; pi2 < path.length - 1; pi2++) {
            pfFillTile(ctx, path[pi2][0], path[pi2][1], 10, color, PF.TERR_PATH_ALPHA, 1.5);
          }

          // Target tile (nearest local territory)
          pfFillTile(ctx, target[0], target[1], 10, color, PF.TERR_TARGET_ALPHA * tpulse, 0.8);
          pfStrokeTile(ctx, target[0], target[1], '#ffffff', 0.7 * tpulse, 1.2);
          ctx.globalAlpha = 0.75 * tpulse;
          ctx.strokeStyle = '#ffffff';
          ctx.lineWidth   = 0.8;
          const tcx = target[0] * 10 + 5, tcy = target[1] * 10 + 5;
          ctx.beginPath();
          ctx.moveTo(tcx - 3, tcy); ctx.lineTo(tcx + 3, tcy);
          ctx.moveTo(tcx, tcy - 3); ctx.lineTo(tcx, tcy + 3);
          ctx.stroke();

          // Head tile glow + ring
          const hx = path[0][0], hy = path[0][1];
          pfFillTile(ctx, hx, hy, 10, color, 0.28 * pulse, 0.5);
          pfDrawHead(ctx, p.pos[0], p.pos[1], color, pulse);

          // Hop count label
          if (path.length > 2) {
            const mid = path[Math.floor(path.length / 2)];
            pfDrawHopLabel(ctx, mid[0], mid[1], (path.length - 1).toString());
          }
        }

        // ── CHANNEL C — Enemy → local trail ────────────────────────────────
        for (let ri = 0; ri < pfTrailPaths.length; ri++) {
          const r      = pfTrailPaths[ri];
          const path   = r.path;
          const target = r.target;
          const p      = r.player;
          const color  = r.color;

          // Dimmer path body
          for (let pi2 = 1; pi2 < path.length - 1; pi2++) {
            pfFillTile(ctx, path[pi2][0], path[pi2][1], 10, color, PF.TRAIL_PATH_ALPHA, 2.0);
          }

          // Target tile — white crosshatch to distinguish from Channel B
          pfFillTile(ctx, target[0], target[1], 10, PF.TRAIL_TARGET_COLOR, PF.TRAIL_TARGET_ALPHA * tpulse, 0.6);
          pfStrokeTile(ctx, target[0], target[1], color, 0.9 * tpulse, 1.4);
          // Diagonal cross on trail-target to tell it apart from territory-target
          ctx.globalAlpha = 0.8 * tpulse;
          ctx.strokeStyle = color;
          ctx.lineWidth   = 0.8;
          const ttcx = target[0] * 10 + 5, ttcy = target[1] * 10 + 5;
          ctx.beginPath();
          ctx.moveTo(ttcx - 3, ttcy - 3); ctx.lineTo(ttcx + 3, ttcy + 3);
          ctx.moveTo(ttcx + 3, ttcy - 3); ctx.lineTo(ttcx - 3, ttcy + 3);
          ctx.stroke();

          // Head ring (only if not already drawn by channel B — check if same player found in pfResults)
          let alreadyHasTerrPath = false;
          for (let bi = 0; bi < pfResults.length; bi++) {
            if (pfResults[bi].player === p) { alreadyHasTerrPath = true; break; }
          }
          if (!alreadyHasTerrPath) {
            const hx = path[0][0], hy = path[0][1];
            pfFillTile(ctx, hx, hy, 10, color, 0.18 * pulse, 0.5);
            pfDrawHead(ctx, p.pos[0], p.pos[1], color, pulse * 0.7);
          }

          // Hop count label
          if (path.length > 2) {
            const mid = path[Math.floor(path.length / 2)];
            pfDrawHopLabel(ctx, mid[0], mid[1], 'T' + (path.length - 1).toString());
          }
        }

        ctx.globalAlpha = 1;
        ctx.restore();
      });
    })();
    // ═══════════════════════════════════════════════════════════════════════
    //  END PATHFINDING ENGINE
    // ═══════════════════════════════════════════════════════════════════════
  }

  function initSettingsPage() {
    const settingsRegistry = {};
    const paletteContainer = document.getElementById('colors');
    const selectAllColors = document.getElementById('colsel');
    const isLegacyEdge = document.documentMode || /Edge/.test(navigator.userAgent);
    let hasCustomSkinColor = typeof getLocalStorage('sha') !== 'undefined' ||
      typeof getLocalStorage('col') !== 'undefined';

    function registerSetting(key, defaultVal) {
      const el = document.getElementById(key);
      if (!el) return; // Safe guard: Skip if element is missing from HTML
      const evType =
        isLegacyEdge && el.tagName !== 'TEXTAREA' && el.type !== 'text' ? 'change' : 'input';
      el.addEventListener(evType, function () {
        if (typeof defaultVal === 'boolean') {
          setLocalStorage(key, this.checked);
        } else {
          setLocalStorage(key, this.value.trim());
        }
        if (key === 'clg2' || key === 'ecc' || key === 'ccol') {
          refreshColorsDisplay();
        }
        if (key === 'thm') {
          handlePresetThemeChange(this.value);
        }
      });
      settingsRegistry[key] = { elem: el, def: defaultVal };
      syncSettingsElement(key);
    }

    function syncSettingsElement(key, checkFocus) {
      if (!settingsRegistry[key]) return;
      const reg = settingsRegistry[key];
      if (reg.def === true) {
        reg.elem.checked = getLocalStorage(key) != 'false';
      } else if (reg.def === false) {
        reg.elem.checked = getLocalStorage(key) == 'true';
      } else if (getLocalStorage(key) == null) {
        reg.elem.value = reg.def;
      } else if (!checkFocus || document.activeElement !== reg.elem || !document.hasFocus()) {
        reg.elem.value = getLocalStorage(key);
      }
      if (key === 'clg2') {
        refreshColorsDisplay();
      }
    }

    function loadSettingsPalette() {
      if (hasCustomSkinColor) {
        document.getElementById('nosha').style.display = 'none';
      }
      const saved = getLocalStorage('col') == null ? true : JSON.parse(getLocalStorage('col'));
      for (let i = 0; i < colorPaletteCheckboxes.length; i++) {
        (saved === true || saved.indexOf(colorPaletteCheckboxes[i].value) === -1) &&
          (colorPaletteCheckboxes[i].checked = true);
        colorPaletteCheckboxes[i].addEventListener('change', onColorPaletteCheckboxChange);
      }
      saved === true ? (selectAllColors.checked = true) : (selectAllColors.indeterminate = true);
    }

    function refreshColorsDisplay() {
      const labels = document.querySelectorAll('#colors label');
      applyBrightnessToColorPalette();
      for (let i = 0; i < labels.length; i++) {
        const v = labels[i].firstElementChild.value;
        labels[i].style.backgroundColor = activeColorPalette[v];
      }
    }

    function resetSettingKey(key) {
      removeLocalStorage(key);
      syncSettingsElement(key);
    }

    function onColorPaletteCheckboxChange() {
      let allChecked = true;
      let noneChecked = true;
      const excluded = [];
      for (let i = 0; i < colorPaletteCheckboxes.length; i++) {
        if (!colorPaletteCheckboxes[i].checked) {
          allChecked = false;
          excluded.push(colorPaletteCheckboxes[i].value);
        } else {
          noneChecked = false;
        }
      }
      if (noneChecked || allChecked) {
        removeLocalStorage('col');
        selectAllColors.checked = !noneChecked;
        selectAllColors.indeterminate = false;
      } else {
        hasCustomSkinColor &&
          ((selectAllColors.checked = false),
          (selectAllColors.indeterminate = true),
          setLocalStorage('col', JSON.stringify(excluded)));
      }
    }

    function onShareClick(e) {
      const popup = window.open(
        this.href,
        '',
        'width=550,height=420,left=' +
          (screen.width / 2 - 275) +
          ',top=80,scrollbars=yes,resizable=yes'
      );
      const check = setInterval(function () {
        popup.closed &&
