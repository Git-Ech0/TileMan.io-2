                  (localPlayer.d === 2 && dinfo.dir === 0) ||
                  (localPlayer.d === 1 && dinfo.dir === 3) ||
                  (localPlayer.d === 3 && dinfo.dir === 1)) {
                continue; 
              }
            }

            var nx = cur.x + dinfo.dx;
            var ny = cur.y + dinfo.dy;
            
            if (nx >= 0 && ny >= 0 && nx < gridSize && ny < gridSize) {
              var nextOwned = isTileOwned(nx, ny);
              var nextOut = nextOwned ? 0 : (cur.out + 1);

              if (nextOut <= 2) {
                var index = nx + ny * gridSize;
                var prevOut = visited.get(index);
                
                if (prevOut === undefined || nextOut < prevOut) {
                  visited.set(index, nextOut);
