(function main(window, document, Math, performance) {
  if (
    !window.requestAnimationFrame ||
    !String.prototype.includes ||
    !('ontouchstart' in window || navigator.maxTouchPoints || 'code' in KeyboardEvent.prototype)
  ) {
    document.getElementById('info').innerHTML =
      'Your browser is too old. Try new Chrome or Firefox.';
    return;
  }

  const clientVersion = 1.2;

  function initTouchLabelFix() {
    const labels = document.getElementsByTagName('label');
    for (let i = 0; i < labels.length; i++) {
      labels[i].addEventListener('mousedown', function (event) {
        event.detail >= 2 &&
          event.detail <= 50 &&
          event.currentTarget.querySelector('input[type=checkbox]') &&
          event.preventDefault();
      });
    }
  }

  function getLocalStorage(key) {
    try {
      return localStorage[key];
    } catch (e) {
      if (history.state && history.state.storage) {
        return history.state.storage[key];
      }
    }
  }

  function setLocalStorage(key, value) {
    value = value.toString();
    try {
      localStorage[key] = value;
    } catch (e) {
      const store = history.state && history.state.storage ? history.state.storage : {};
      store[key] = value;
      if (history.state) {
        history.replaceState({ playing: history.state.playing, storage: store }, '');
      } else {
        history.replaceState({ storage: store }, '');
      }
    }
    return value;
  }

  function removeLocalStorage(key) {
    try {
      localStorage.removeItem(key);
    } catch (e) {
      const store = history.state && history.state.storage ? history.state.storage : {};
      delete store[key];
      if (history.state) {
        history.replaceState({ playing: history.state.playing, storage: store }, '');
      } else {
        history.replaceState({ storage: store }, '');
      }
    }
  }

  function applyBrightnessToColorPalette() {
    const brightnessOffset =
      typeof getLocalStorage('clg2') !== 'undefined' ? getLocalStorage('clg2') : '0';
    for (let i = 0; i < colorPalette.length; i++) {
      const baseColor = colorPalette[i];
      let modifiedColor;
      if (brightnessOffset > 0) {
        modifiedColor = chroma(baseColor).brighten(brightnessOffset).toString();
      } else if (brightnessOffset < 0) {
        modifiedColor = chroma(baseColor).darken(-brightnessOffset).toString();
      } else {
        modifiedColor = baseColor;
      }
      activeColorPalette[baseColor] = modifiedColor;
      alphaColorPalette[modifiedColor] = chroma(modifiedColor)
        .brighten(2.2)
        .saturate(0.7)
        .alpha(0)
        .css()
        .slice(0, -2);
    }

    const isCustomEnabled = getLocalStorage('ecc') === 'true';
    const customCol = getLocalStorage('ccol') || '#ff0000';
    if (isCustomEnabled && lastAssignedSelfColor) {
      let modifiedCustomColor;
      if (brightnessOffset > 0) {
        modifiedCustomColor = chroma(customCol).brighten(brightnessOffset).toString();
      } else if (brightnessOffset < 0) {
        modifiedCustomColor = chroma(customCol).darken(-brightnessOffset).toString();
      } else {
        modifiedCustomColor = customCol;
      }
      activeColorPalette[lastAssignedSelfColor] = modifiedCustomColor;
      alphaColorPalette[modifiedCustomColor] = chroma(modifiedCustomColor)
        .brighten(2.2)
        .saturate(0.7)
        .alpha(0)
        .css()
        .slice(0, -2);
    }
  }

  function applyThemePreset(preset) {
    document.body.className = document.body.className.replace(/\btheme-\w+/g, '').trim();
    if (preset && preset !== 'default') {
      document.body.classList.add('theme-' + preset);
    }
  }

  function handlePresetThemeChange(preset) {
    applyThemePreset(preset);

    const themeColors = {
      default: { bg: '#333333', bgem: '#666666', bgwa: '#999999' },
      cyberpunk: { bg: '#0a0014', bgem: '#1a0033', bgwa: '#00f0ff' },
      space: { bg: '#02020a', bgem: '#0d1127', bgwa: '#7b2cbf' },
      retro: { bg: '#0a0f0d', bgem: '#121a16', bgwa: '#39ff14' },
      light: { bg: '#ffffff', bgem: '#f3f4f6', bgwa: '#ff4757' },
      slate: { bg: '#0c0f12', bgem: '#12161b', bgwa: '#f39c12' },
    };

    const colors = themeColors[preset] || themeColors.default;
    setLocalStorage('bg', colors.bg);
    setLocalStorage('bgem', colors.bgem);
    setLocalStorage('bgwa', colors.bgwa);

    cellBgColor = colors.bg;
    emptyCellColor = colors.bgem;

    const elBg = document.getElementById('bg');
    const elBgem = document.getElementById('bgem');
    const elBgwa = document.getElementById('bgwa');
    if (elBg) elBg.value = colors.bg;
    if (elBgem) elBgem.value = colors.bgem;
    if (elBgwa) elBgwa.value = colors.bgwa;
  }

  // Initialize the theme immediately on load
  applyThemePreset(getLocalStorage('thm') || 'default');

  const colorPalette = [
      '#7c0000',
      '#bd002b',
      '#ff0000',
      '#ff7378',
      '#b64200',
      '#ff6000',
      '#633000',
