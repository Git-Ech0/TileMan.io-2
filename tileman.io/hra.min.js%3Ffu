    // Rasterizes every OTHER live player's trail, plus their current head
    // tile, into one Set. Feeds the look-ahead predictor in
    // changeDirection() so a queued turn that would run into anyone else's
    // trail or head gets rejected.
    //
    // Trail cells are territory-filtered per owner (an enemy's just-closed
    // loop shouldn't keep reading as trail once it's their land). Head tiles are NOT
    // territory-filtered: intentionally unconditional, so a head sitting
    // on the enemy's own turf is still avoided. This is a deliberate
    // product decision (avoid every other player unconditionally, trail
    // and head alike) — don't "simplify" it back to matching pfBarriers'
    // territory-aware head logic further down this file, that's a
    // different subsystem (enemy-path prediction) with different goals.
    // Localized friendly-fire guard: only players we can actually confirm
    // are running the mod and sharing our match over the P2P mesh (see
    // getRemoteMatchPlayers() in network-mod.js) get avoided here. Everyone
    // else in the match is fair game, same as vanilla — this is a "don't
    // let me step on my own people" guard, not a general safety net.
    //
    // Matched on name alone (case-insensitive), not player.id. id-based
    // matching was tried first but proved too strict in practice — the id
    // a teammate reports over the P2P mesh doesn't reliably line up with
    // how this client sees them in the local `players` array, so real
    // teammates were routinely falling through and getting treated as
    // hazards. Name collisions are the tradeoff (two different players
    // sharing a name would both get protected), but that's a rarer and
    // less disruptive failure mode than the guard silently not
    // recognizing your own teammates.
    function getP2PProtectedKeySet() {
      // FF setting: if the user turned it off, return empty set immediately
      // (empty set = no hazard cells added = you can run into P2P players freely).
      if (getLocalStorage('ff') === 'false') return new Set();

      // Arena gamemode: FF intentionally disabled — the whole point is to
      // fight, so ramming P2P teammates should be allowed like everyone else.
      if (selectedMode === 'arena') return new Set();

      const T = window.TamState;
      const keys = new Set();

      // Primary source: ping-registry names via getP2PPlayerNames().
      // This works even when a peer has ghost mode on (no position broadcast)
      // or allowSpectating=false — they still send heartbeat pings so their
      // name lands here and FF stays active for them.
      if (T && T.getP2PPlayerNames) {
        const pingNames = T.getP2PPlayerNames();
        for (let i = 0; i < pingNames.length; i++) {
          if (pingNames[i]) keys.add(String(pingNames[i]).toLowerCase());
        }
      }

      // Fallback / supplement: position broadcast names via getRemoteMatchPlayers().
      // Catches any peer whose ping landed between health sweeps but whose
      // positionAction fired more recently (e.g. first few seconds of a session).
      if (T && T.getRemoteMatchPlayers) {
        const remotePlayers = T.getRemoteMatchPlayers();
        for (let i = 0; i < remotePlayers.length; i++) {
          const rp = remotePlayers[i];
          if (rp && rp.name) keys.add(String(rp.name).toLowerCase());
        }
      }

      return keys;
    }

    function isP2PProtected(p, protectedKeys) {
      if (!p.na) return false;
      return protectedKeys.has(String(p.na).toLowerCase());
    }

    // Walks the axis-aligned hop from player.framePos (where they were the
    // last time the per-frame players loop snapshotted them, right before
    // their own movePlayer() call) to player.pos (where they are right now),
    // calling visit(cx, cy) for every tile-cell along the way, inclusive of
    // both ends. Unconditional — no territory filtering — matching every
    // other "head" hazard check in this file, which is deliberately
    // unconditional too (see the note on buildOtherPlayerHazardCellSet).
    //
    // Why this exists instead of just checking player.pos directly: at
    // normal speeds framePos and pos round to the same tile almost always,
    // so this collapses to the single-point check it replaces. But
    // distStep (a player's per-frame movement) scales directly with
    // serverSpeed — see the main render loop — and on a high-multiplier
    // mode like Extreme Speed a player can cross more than one tile inside
    // a single animation frame. Sampling only the final point they land on
    // each frame then misses every tile they actually crossed to get there,
    // which is exactly the "flies past without triggering anything" gap:
    // the fast player's own hazard footprint tunnels through the check
    // unseen because it was only ever a single dot, not a swept line.
    function rasterizeHeadSweep(player, visit) {
