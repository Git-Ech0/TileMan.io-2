      '#00c500',
      '#00ff00',
      '#009062',
      '#00c679',
      '#00ff8f',
      '#00ffce',
      '#007c78',
      '#00cebd',
      '#00aab9',
      '#00f6ff',
      '#005270',
      '#007eb6',
      '#00afff',
      '#00d1ff',
      '#002f6f',
      '#0057ba',
      '#0087ff',
      '#2400b3',
      '#0000ff',
      '#4464ff',
      '#8299ff',
      '#4e00ff',
      '#5558a1',
      '#280073',
      '#5200c2',
      '#8066ff',
      '#8400ff',
      '#b9a2ff',
      '#5d0096',
      '#8154b7',
      '#ac00ff',
      '#ca75ff',
      '#5a0067',
      '#8f00b5',
      '#d500ff',
      '#ba00bc',
      '#ff00ff',
      '#8b0078',
      '#b967a7',
      '#ff00c9',
      '#ff7fea',
      '#65003e',
      '#c40089',
      '#a60055',
      '#ff0094',
      '#ff86b6',
      '#aa6675',
      '#f1005e',
    ],
    DEFAULT_BACKGROUND_COLOR = '#333333',
    DEFAULT_EMPTY_CELL_COLOR = '#666666';

  // Palette state: activeColorPalette/alphaColorPalette are mutated in place (never
  // reassigned wholesale), so they stay const. lastAssignedSelfColor changes whenever
  // the local player's color is (re)assigned, so it needs let.
  const activeColorPalette = {};
  const alphaColorPalette = {};
  let lastAssignedSelfColor = null;

  applyBrightnessToColorPalette();

  function initGame() {
    function injectP2PStyles() {
      // Visual styling for #p2p-panel and friends now lives in style.css
      // (kept in sync with the rest of the game UI). This function is kept
      // as a no-op so existing call sites don't need to change.
    }

    let p2pPanelResized = false,
      p2pCustomWidth = null,
      p2pCustomHeight = null,
      p2pPanelMoved = false,
      p2pCustomLeft = null,
      p2pCustomTop = null;

    // Computes the on-screen CSS box (in viewport pixels) that the minimap
    // occupies. Mirrors the math used when the minimap is actually drawn
    // onto the game canvas (see the mmSize/mmMargin calc in the render
    // loop), but only depends on viewport size, so it also works before a
    // match has started (i.e. on the lobby screen).
    function getMinimapBoxCss() {
      // Note: the minimap's on-screen CSS size works out to
      // min(200, vw/2.5, vh/2, (vw+vh)/7) — the device-pixel-ratio and
      // resolution-multiplier terms in the canvas-space formula cancel out
      // once converted back to CSS pixels, so they're intentionally not
      // referenced here.
      const vw = window.innerWidth,
        vh = window.innerHeight;
      let size = Math.min(200, vw / 2.5, vh / 2, (vw + vh) / 7);
      size = Math.max(size, 90);
      return { left: 5, top: 5, width: size, height: size };
    }

    // Works out where the Player Tab panel should sit by default: nested
    // directly under the minimap, matching its width, and reaching down to
    // just above the "Spectators:" row (or a sensible fallback on the
    // lobby screen, where that row doesn't exist yet).
    function getP2PLayoutBounds() {
      const margin = 10;
      const mm = getMinimapBoxCss();
      const left = mm.left;
      const top = mm.top + mm.height + margin;
      let bottomLimit;
      if (gameContainer && gameContainer.style.display !== 'none' && leftbottom) {
        const r = leftbottom.getBoundingClientRect();
        if (r.top > 0 && (r.width > 0 || r.height > 0)) {
          bottomLimit = r.top - margin;
        }
      }
      if (bottomLimit === undefined) {
        bottomLimit = window.innerHeight - margin;
      }
      const maxWidth = Math.max(window.innerWidth - left - margin, 90);
      const maxHeight = Math.max(bottomLimit - top, 80);
      return {
        left: left,
        top: top,
        defaultWidth: mm.width,
        defaultHeight: maxHeight,
        maxWidth: maxWidth,
        maxHeight: maxHeight,
      };
    }

    function positionP2PPanel() {
      const panel = document.getElementById('p2p-panel');
      if (!panel) return;
      const b = getP2PLayoutBounds();
      if (!p2pPanelMoved) {
        panel.style.left = b.left + 'px';
        panel.style.top = b.top + 'px';
      } else {
        const maxLeft = Math.max(window.innerWidth - panel.offsetWidth - 2, 0);
        const maxTop = Math.max(window.innerHeight - panel.offsetHeight - 2, 0);
        p2pCustomLeft = Math.min(Math.max(p2pCustomLeft, 0), maxLeft);
        p2pCustomTop = Math.min(Math.max(p2pCustomTop, 0), maxTop);
        panel.style.left = p2pCustomLeft + 'px';
        panel.style.top = p2pCustomTop + 'px';
      }
      if (!p2pPanelResized) {
        panel.style.width = b.defaultWidth + 'px';
        panel.style.height = b.defaultHeight + 'px';
      } else {
        const w = Math.min(p2pCustomWidth || b.defaultWidth, b.maxWidth);
        const h = Math.min(p2pCustomHeight || b.defaultHeight, b.maxHeight);
        panel.style.width = Math.max(w, 90) + 'px';
        panel.style.height = Math.max(h, 80) + 'px';
      }
    }

    // Lets the panel be dragged around by its header, and remembers where
    // it was dropped.
    function initP2PPanelDrag(panel, header) {
      const DRAG_THRESHOLD = 4; // px of movement before a press counts as a drag, not a tab click
      let justDragged = false;

      // Runs in the capture phase, i.e. before the click reaches whichever
      // tab button the pointer happened to land on, so a drag never also
      // fires that button's click handler.
      header.addEventListener(
        'click',
        function (e) {
          if (justDragged) {
            e.stopPropagation();
            e.preventDefault();
            justDragged = false;
          }
        },
        true
      );

      header.addEventListener('pointerdown', function (e) {
        const rect = panel.getBoundingClientRect();
        const startX = e.clientX,
          startY = e.clientY;
        const startLeft = rect.left,
          startTop = rect.top;
        let dragging = false;

        function onMove(ev) {
          const dx = ev.clientX - startX;
          const dy = ev.clientY - startY;
          if (!dragging) {
            if (Math.abs(dx) < DRAG_THRESHOLD && Math.abs(dy) < DRAG_THRESHOLD) return;
            dragging = true;
            if (e.pointerId !== undefined && header.setPointerCapture) {
              try {
                header.setPointerCapture(e.pointerId);
              } catch (err) {}
            }
          }
          p2pPanelMoved = true;
          p2pCustomLeft = startLeft + dx;
          p2pCustomTop = startTop + dy;
          positionP2PPanel();
        }
        function onUp() {
          window.removeEventListener('pointermove', onMove);
          window.removeEventListener('pointerup', onUp);
          if (dragging) {
            justDragged = true;
            try {
              setLocalStorage('p2p_x', panel.offsetLeft);
              setLocalStorage('p2p_y', panel.offsetTop);
            } catch (err) {}
          }
        }
        window.addEventListener('pointermove', onMove);
        window.addEventListener('pointerup', onUp);
      });

      const storedX = parseFloat(getLocalStorage('p2p_x'));
      const storedY = parseFloat(getLocalStorage('p2p_y'));
      if (!isNaN(storedX) && !isNaN(storedY)) {
        p2pPanelMoved = true;
        p2pCustomLeft = storedX;
        p2pCustomTop = storedY;
      }
    }

    // Wires up invisible drag strips along the bottom and right edges (plus
    // a small corner for diagonal resizing) so the panel can be resized
    // without showing any resize affordance.
    function initP2PPanelResize(panel) {
      function beginDrag(mode) {
        return function (e) {
          e.preventDefault();
          const startX = e.clientX,
            startY = e.clientY;
          const rect = panel.getBoundingClientRect();
          const startW = rect.width,
            startH = rect.height;
          if (e.pointerId !== undefined && e.target.setPointerCapture) {
            try {
              e.target.setPointerCapture(e.pointerId);
            } catch (err) {}
          }

          function onMove(ev) {
            const b = getP2PLayoutBounds();
            if (mode === 'right' || mode === 'corner') {
              p2pCustomWidth = Math.max(90, Math.min(startW + (ev.clientX - startX), b.maxWidth));
              panel.style.width = p2pCustomWidth + 'px';
            }
            if (mode === 'bottom' || mode === 'corner') {
              p2pCustomHeight = Math.max(80, Math.min(startH + (ev.clientY - startY), b.maxHeight));
              panel.style.height = p2pCustomHeight + 'px';
            }
            p2pPanelResized = true;
          }
          function onUp() {
            window.removeEventListener('pointermove', onMove);
            window.removeEventListener('pointerup', onUp);
            if (p2pPanelResized) {
              try {
                setLocalStorage('p2p_w', panel.offsetWidth);
                setLocalStorage('p2p_h', panel.offsetHeight);
              } catch (err) {}
            }
          }
          window.addEventListener('pointermove', onMove);
          window.addEventListener('pointerup', onUp);
        };
      }

      const rightHandle = document.createElement('div');
      rightHandle.className = 'p2p-resize-handle p2p-resize-right';
      rightHandle.addEventListener('pointerdown', beginDrag('right'));
      panel.appendChild(rightHandle);

      const bottomHandle = document.createElement('div');
      bottomHandle.className = 'p2p-resize-handle p2p-resize-bottom';
      bottomHandle.addEventListener('pointerdown', beginDrag('bottom'));
      panel.appendChild(bottomHandle);

      const cornerHandle = document.createElement('div');
      cornerHandle.className = 'p2p-resize-handle p2p-resize-corner';
      cornerHandle.addEventListener('pointerdown', beginDrag('corner'));
      panel.appendChild(cornerHandle);

      const storedW = parseFloat(getLocalStorage('p2p_w'));
      const storedH = parseFloat(getLocalStorage('p2p_h'));
      if (!isNaN(storedW) && !isNaN(storedH)) {
        p2pPanelResized = true;
        p2pCustomWidth = storedW;
        p2pCustomHeight = storedH;
      }
    }

    function initP2PVisuals() {
      if (document.getElementById('p2p-panel')) return;

      const p2pPanel = document.createElement('div');
      p2pPanel.id = 'p2p-panel';

      const p2pTabs = document.createElement('div');
      p2pTabs.className = 'p2p-tabs';
      p2pTabs.innerHTML =
        '<button type="button" class="p2p-tab-btn active" id="p2p-tab-players" data-tab="players">Players</button>' +
        '<button type="button" class="p2p-tab-btn" id="p2p-tab-chat" data-tab="chat">Chat<span class="p2p-tab-dot" id="p2p-chat-dot"></span></button>';
      p2pPanel.appendChild(p2pTabs);

      const p2pBody = document.createElement('div');
      p2pBody.id = 'p2p-body';

      const p2pList = document.createElement('div');
      p2pList.id = 'p2p-list';
      p2pList.innerHTML = '<div class="p2p-status-message">Connecting to P2P network...</div>';
      p2pBody.appendChild(p2pList);

      // Chat is peer-to-peer only — nothing here is ever persisted, so a
      // reload or a fresh join starts with an empty log. See network-mod.js
      // for the room-wide broadcast/receive wiring.
      const p2pChat = document.createElement('div');
      p2pChat.id = 'p2p-chat';
      p2pChat.style.display = 'none';

      const p2pChatMessages = document.createElement('div');
      p2pChatMessages.id = 'p2p-chat-messages';
      p2pChatMessages.innerHTML = '<div class="p2p-status-message">No messages yet — say hi!</div>';
      p2pChat.appendChild(p2pChatMessages);

      const p2pChatInputRow = document.createElement('div');
      p2pChatInputRow.id = 'p2p-chat-input-row';

      const p2pChatInput = document.createElement('input');
      p2pChatInput.id = 'p2p-chat-input';
      p2pChatInput.type = 'text';
      p2pChatInput.maxLength = 300;
      p2pChatInput.placeholder = 'Message everyone…';
      p2pChatInput.autocomplete = 'off';
      p2pChatInputRow.appendChild(p2pChatInput);

      const p2pChatSend = document.createElement('button');
