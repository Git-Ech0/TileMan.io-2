    // gridMatrix snapshot? Generic over `player` so it works for the local
    // player and for every remote player alike.
    //
    // Why this matters: a trail only stops being a hazard once the server
    // confirms a capture, and that confirmation arrives as two separate
    // pieces of state that don't necessarily land the same tick — the
    // gridMatrix repaint (cells flip to the owner's color) and the trs
    // update (the closed loop's vertices drop out of the array). Right
    // after a loop closes there's a real window where a tile is
    // simultaneously "owned" in gridMatrix and still sitting in trs from
    // the payload that hasn't been superseded yet. Any trail-hazard builder
    // that rasterizes trs without this check will therefore keep treating
    // freshly-filled land as solid trail for a few ticks — that's the
    // false movement-cancel / stuck-pause bug on quick re-exits. Every
    // trail rasterizer in this file (own trail below, other players'
    // trails further down, and the physical clamp in findTrailBlockIndex)
    // routes through this same check so none of them can reintroduce it.
    function isOwnedTerritoryTile(player, tx, ty) {
      if (tx < 0 || ty < 0 || tx >= gridSize || ty >= gridSize) return false;
      const cell = gridMatrix[tx] && gridMatrix[tx][ty];
      if (!cell) return false;
      const cellColor = String(cell.c).toLowerCase();
