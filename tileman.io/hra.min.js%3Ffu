          var hx = Math.floor(p.pos[0])
          var hy = Math.floor(p.pos[1])
          if (hx < 0 || hy < 0 || hx >= gs || hy >= gs) continue

          var headCell  = gm[hx] && gm[hx][hy]
          var headColor = headCell ? headCell.c : null
          // Compare raw color strings — gridMatrix stores raw player.c values
