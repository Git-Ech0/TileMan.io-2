        const py = localPlayer.pos[1];
        const wouldHitWallEdge =
          (heading === 0 && px >= gridSize - 2) ||   // right → right wall
          (heading === 1 && py >= gridSize - 2) ||   // down  → bottom wall
          (heading === 2 && px <= 1)             ||  // left  → left wall
          (heading === 3 && py <= 1);                // up    → top wall
        if (wouldHitWallEdge) {
          // Pause instead of silent drop — player stops at the wall edge.
          changeDirection(4);
        }
        return;
      }
      // ══════════════════════════════════════════════

      if ((getLocalStorage('movq') === 'false' ? inputQueue.length > 0 : inputQueue.length > 2) && heading != 4) return;
      const gx =
        localPlayer.pos[0] === Math.floor(localPlayer.pos[0])
          ? localPlayer.pos[0]
          : Math.floor(localPlayer.pos[0]) + 0.5;
      const gy =
        localPlayer.pos[1] === Math.floor(localPlayer.pos[1])
          ? localPlayer.pos[1]
          : Math.floor(localPlayer.pos[1]) + 0.5;
      if (
        heading == lastDirectHeading &&
        (performance.now() - lastDirectionSentTime < 70 ||
          (gx == lastSyncedGridX && gy == lastSyncedGridY && localPlayer.d !== 4))
      ) {
        return;
      }
      lastSyncedGridX = gx;
      lastSyncedGridY = gy;
      lastDirectDirection = heading;
      if (!(inputQueue.length > 0 && heading === inputQueue[inputQueue.length - 1])) {
        inputQueue.push(heading);
        localSyncedClock += performance.now() - clockCheckpoint;
        if (inputQueue.length < 2) {
          lastHeadingChangeTime = localSyncedClock;
        }
        clockCheckpoint = performance.now();
        socket.emit('\u202D\u202D1\u202D', [
          heading,
          gx,
          gy,
          Math.floor(localSyncedClock),
          rngSeed,
        ]);
        if (heading !== lastDirectHeading && spawnInputMovesCount < 2) {
          spawnInputMovesCount++;
          if (spawnInputMovesCount === 2 && isSessionValid) {
            addDeathsCount(0.5);
          }
        }
        lastMousePos = [currentMousePos[0], currentMousePos[1]];
        document.body.style.cursor = 'none';
      }
      lastDirectHeading = heading;
      lastDirectionSentTime = performance.now();
    }

    function sendEmoteInput(id) {
      if (!(localPlayer && socket) || performance.now() - lastEmoteBroadcast < 50) return;
      lastEmoteBroadcast = performance.now();
      socket.emit('2', id);
    }

    function renderActiveGrid() {
