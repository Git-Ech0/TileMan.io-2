      const liveLimitY = window.pl(13, 1, isArenaResetActive);

      let rx = window.pl(22, 1, isArenaResetActive),
        ry = window.pl(13, 1, isArenaResetActive),
        overlap = 0;

      if (isCameraZoomEnabled) {
        const scaleMultiplier = 1.0 / cameraZoomFactor;
        rx = Math.round(rx * scaleMultiplier);
        ry = Math.round(ry * scaleMultiplier);
        // Smooth overlap transition to eliminate subpixel gap jumpiness
        overlap = Math.max(0, (1.05 - cameraZoomFactor) * 0.5);
      }

      const minX = Math.max(cameraPos[0] - rx, 0);
      const minY = Math.max(cameraPos[1] - ry, 0);
      const maxX = Math.min(cameraPos[0] + rx, gridSize - 1);
      const maxY = Math.min(cameraPos[1] + ry, gridSize - 1);
