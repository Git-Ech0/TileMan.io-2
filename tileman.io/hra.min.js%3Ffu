      }

      function pfRasterSeg(x0, y0, x1, y1, out) {
        var ix0 = Math.floor(x0), iy0 = Math.floor(y0)
        var ix1 = Math.floor(x1), iy1 = Math.floor(y1)
        var dx  = Math.sign(ix1 - ix0)
        var dy  = Math.sign(iy1 - iy0)
        var cx  = ix0, cy = iy0
        var lim = Math.abs(ix1 - ix0) + Math.abs(iy1 - iy0) + 1
